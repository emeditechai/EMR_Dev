@{
    ViewData["Title"] = "Doctor Roster";
    var doctors = ViewBag.Doctors as IEnumerable<(int DoctorId, string FullName, int? PrimarySpecialityId, string Gender)>;
}

@section HeadStyles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js'></script>
    <style>
        /* ── One-screen layout ─────────────────────────────────── */
        .roster-page {
            display: flex;
            flex-direction: column;
            height: calc(100vh - var(--roster-offset, 130px));
            min-height: 0;
        }

        /* ── Compact Toolbar ───────────────────────────────────── */
        .roster-toolbar {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 16px;
            background: #fff;
            border: 1px solid #eef0fb;
            border-radius: 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,.05);
            flex-shrink: 0;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }
        .toolbar-label {
            font-size: .78rem;
            font-weight: 700;
            color: #475569;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .toolbar-select-wrap {
            flex: 0 0 260px;
        }
        .toolbar-select-wrap .select2-container {
            min-width: 220px;
        }
        .toolbar-divider {
            width: 1px;
            height: 28px;
            background: #e2e8f0;
            flex-shrink: 0;
        }
        .toolbar-legends {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
            flex: 1;
            justify-content: flex-end;
        }

        /* ── Legend Pills ──────────────────────────────────────── */
        .legend-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: .72rem;
            font-weight: 600;
            border: 1px solid transparent;
            white-space: nowrap;
        }
        .legend-pill .dot { width: 8px; height: 8px; border-radius: 50%; }
        .lp-avail  { background: #ede9fe; color: #5b21b6; border-color: #ddd6fe; }
        .lp-booked { background: #d1fae5; color: #065f46; border-color: #a7f3d0; }
        .lp-full   { background: #ffe4e6; color: #9f1239; border-color: #fecdd3; }
        .lp-leave  { background: #fef3c7; color: #92400e; border-color: #fde68a; }

        /* ── Calendar Container ────────────────────────────────── */
        .calendar-wrap {
            flex: 1;
            min-height: 0;
            background: #fff;
            border: 1px solid #eef0fb;
            border-radius: 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,.05);
            overflow: hidden;
            position: relative;
        }
        #calendar {
            height: 100%;
            font-family: inherit;
        }

        /* ── Loading / Empty ───────────────────────────────────── */
        .roster-loading {
            position: absolute; inset: 0;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            background: #fff; z-index: 10;
        }
        .spinner-ring {
            width: 46px; height: 46px;
            border: 4px solid #eef0fb;
            border-top-color: #667eea;
            border-radius: 50%;
            animation: spin .7s linear infinite;
            margin-bottom: 12px;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }
        .empty-state {
            position: absolute; inset: 0;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
        }
        .empty-state .es-icon {
            width: 64px; height: 64px;
            background: linear-gradient(135deg, #eef0fb, #e0e7ff);
            border-radius: 50%;
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 1.6rem; margin-bottom: 12px; color: #667eea;
        }

        /* ── FullCalendar Overrides ────────────────────────────── */
        .fc .fc-toolbar { padding: 8px 14px !important; }
        .fc .fc-toolbar-title { font-size: 1.05em !important; font-weight: 700 !important; color: #1e293b !important; }
        .fc .fc-button-primary {
            background: linear-gradient(135deg, #667eea, #764ba2) !important;
            border-color: transparent !important;
            border-radius: 7px !important;
            font-weight: 600 !important;
            font-size: .78rem !important;
            padding: 4px 10px !important;
            box-shadow: 0 2px 8px rgba(102,126,234,.3) !important;
        }
        .fc .fc-button-primary:hover { opacity: .88 !important; }
        .fc .fc-button-primary:not(:disabled).fc-button-active {
            background: linear-gradient(135deg, #764ba2, #667eea) !important;
        }
        .fc-day-today { background: linear-gradient(180deg, rgba(102,126,234,.07) 0%, rgba(102,126,234,.03) 100%) !important; }
        .fc-col-header-cell { padding: 5px 0 !important; }
        .fc-col-header-cell-cushion {
            font-weight: 700 !important; color: #6c6f93 !important;
            text-transform: uppercase !important; font-size: .68rem !important;
            letter-spacing: .06em !important; text-decoration: none !important;
        }
        .fc-daygrid-day-number {
            font-weight: 600 !important; color: #374151 !important;
            text-decoration: none !important; font-size: .78rem !important;
            padding: 3px 6px !important;
        }
        .fc-daygrid-day-number:hover { color: #667eea !important; }

        /* ── Calendar Events ───────────────────────────────────── */
        .fc-event {
            cursor: pointer !important;
            border-radius: 6px !important;
            border: none !important;
            font-size: .68rem !important;
            font-weight: 600 !important;
            padding: 2px 5px !important;
            transition: transform .12s ease, box-shadow .12s ease !important;
            box-shadow: 0 1px 4px rgba(0,0,0,.1) !important;
        }
        .fc-event:hover {
            transform: translateY(-1px) scale(1.02) !important;
            box-shadow: 0 4px 12px rgba(0,0,0,.15) !important;
            z-index: 10 !important;
        }
        .fc-event.ev-available { background: linear-gradient(135deg, #667eea, #764ba2) !important; color: #fff !important; }
        .fc-event.ev-booked    { background: linear-gradient(135deg, #11998e, #38ef7d) !important; color: #fff !important; }
        .fc-event.ev-full      { background: linear-gradient(135deg, #f093fb, #f5576c) !important; color: #fff !important; }
        .fc-event.ev-exception { background: linear-gradient(135deg, #ffecd2, #fcb69f) !important; color: #7a2d2d !important; }
        .fc-day-past .fc-event { opacity: .6; }

        /* ── Slot Modal ────────────────────────────────────────── */
        #slotsModal .modal-content { border-radius: 20px; overflow: hidden; }
        #slotsModal .modal-header {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-bottom: none; padding: 18px 22px;
        }
        #slotsModal .modal-title { color: #fff; font-weight: 700; }
        #slotsModal .btn-close { filter: invert(1) brightness(2); }
        .slot-btn {
            transition: all .2s ease;
            border-radius: 12px !important;
        }
        .slot-btn:hover:not(:disabled) {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,.12) !important;
        }
        .slot-btn:disabled {
            opacity: .55; cursor: not-allowed;
            background: #f1f5f9 !important; border-color: #e2e8f0 !important; color: #94a3b8 !important;
        }
        .slot-available { background: linear-gradient(135deg, #667eea15, #764ba215) !important; border-color: #667eea !important; }
        .slot-available:hover { background: linear-gradient(135deg, #667eea25, #764ba225) !important; }

        /* ── Hover Tooltip ─────────────────────────────────────── */
        #rosterTooltip {
            position: fixed;
            z-index: 9999;
            min-width: 280px; max-width: 340px;
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 16px 48px rgba(0,0,0,.16), 0 2px 8px rgba(102,126,234,.12);
            border: 1.5px solid #e0e7ff;
            padding: 0;
            pointer-events: auto;
            opacity: 0;
            transform: translateY(8px) scale(0.96);
            transition: opacity .18s ease, transform .18s ease;
            font-size: 0.82rem;
        }
        #rosterTooltip.show { opacity: 1; transform: translateY(0) scale(1); }
        .rt-header {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff; border-radius: 12px 12px 0 0;
            padding: 8px 12px;
            display: flex; align-items: center; justify-content: space-between;
        }
        .rt-header .rt-date  { font-weight: 700; font-size: .84rem; }
        .rt-header .rt-count {
            background: rgba(255,255,255,.2); border-radius: 20px;
            padding: 2px 8px; font-size: .72rem; font-weight: 600;
        }
        .rt-body { padding: 6px 10px 8px; max-height: 300px; overflow-y: auto; }
        .rt-body::-webkit-scrollbar { width: 6px; }
        .rt-body::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 4px; }
        .rt-body::-webkit-scrollbar-thumb { background: #a5b4fc; border-radius: 4px; }
        .rt-body::-webkit-scrollbar-thumb:hover { background: #667eea; }
        .rt-item {
            display: flex; align-items: flex-start; gap: 8px;
            padding: 6px 8px; border-radius: 8px; margin-bottom: 4px;
            border: 1px solid #eef0fb; background: #fafbff;
        }
        .rt-item:last-child { margin-bottom: 0; }
        .rt-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: linear-gradient(135deg, #e0e7ff, #c7d2fe); color: #4f46e5;
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: .68rem; flex-shrink: 0;
        }
        .rt-info { flex: 1; min-width: 0; }
        .rt-name { font-weight: 700; color: #1e293b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: .79rem; }
        .rt-sub  { color: #64748b; font-size: .7rem; margin-top: 1px; }
        .rt-badge-r { background: #dbeafe; color: #1d4ed8; }
        .rt-badge-c { background: #d1fae5; color: #065f46; }
        .rt-badge-x { background: #fee2e2; color: #991b1b; }
        .rt-slot { font-size: .72rem; color: #667eea; font-weight: 700; white-space: nowrap; flex-shrink: 0; }
        .rt-empty { text-align: center; padding: 12px 0; color: #94a3b8; font-size: .78rem; }
        .rt-footer {
            border-top: 1px solid #eef0fb;
            padding: 5px 12px; font-size: .72rem; color: #64748b;
            border-radius: 0 0 12px 12px; background: #f8faff;
            display: flex; align-items: center; justify-content: space-between;
        }

        /* ── Select2 compact ───────────────────────────────────── */
        .select2-container--bootstrap-5 .select2-selection {
            font-size: .82rem !important;
            padding: 3px 8px !important;
            min-height: 32px !important;
        }

        /* ── Capacity Progress Bar on Event Pills ───────────────── */
        .fc-event { position: relative !important; overflow: hidden !important; }
        .ev-bar {
            position: absolute; bottom: 0; left: 0; right: 0;
            height: 3px; border-radius: 0 0 5px 5px;
            background: rgba(255,255,255,.25); overflow: hidden;
        }
        .ev-bar-fill { height: 100%; border-radius: 0 0 5px 5px; transition: width .4s ease; }

        /* ── Day Booking Count Badge ────────────────────────────── */
        .day-bkd-badge {
            display: inline-flex; align-items: center; gap: 2px;
            font-size: .58rem; font-weight: 700;
            color: #065f46; background: #d1fae5;
            border-radius: 10px; padding: 0px 5px;
            margin-left: 3px; vertical-align: middle; line-height: 1.6;
        }
        .day-bkd-badge.many { color: #92400e; background: #fef3c7; }

        /* ── Quick Book Button in Tooltip ──────────────────────── */
        .rt-book-btn {
            width: 100%; padding: 8px 14px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff; border: none; border-radius: 0 0 12px 12px;
            font-size: .78rem; font-weight: 700;
            cursor: pointer; transition: opacity .15s ease;
            display: flex; align-items: center; justify-content: center; gap: 6px;
        }
        .rt-book-btn:hover:not(:disabled) { opacity: .88; }
        .rt-book-btn:disabled {
            background: #f1f5f9; color: #94a3b8;
            cursor: not-allowed; border-top: 1px solid #e2e8f0;
        }

        /* ── Compact / Expanded Toggle Button ───────────────────── */
        .btn-compact {
            padding: 4px 10px; font-size: .73rem; font-weight: 600;
            border-radius: 7px; border: 1.5px solid #667eea;
            color: #667eea; background: #fff;
            cursor: pointer; transition: all .15s ease; white-space: nowrap;
            display: inline-flex; align-items: center; gap: 4px;
        }
        .btn-compact:hover, .btn-compact.active {
            background: linear-gradient(135deg,#667eea,#764ba2);
            color: #fff; border-color: transparent;
        }

        /* ── Week-View Rich Event Content ────────────────────────── */
        .ev-custom { padding: 2px 4px; line-height: 1.25; min-height: 100%; }
        .ev-custom .ev-title { font-weight: 700; font-size: .71rem; }
        .ev-custom .ev-sub   { font-size: .64rem; opacity: .86; margin-top: 1px; }

        /* ── FullCalendar flexible rows ─────────────────────────── */
        .fc .fc-daygrid-day-frame  { min-height: 80px !important; }
        .fc .fc-daygrid-body-natural .fc-daygrid-day-events { padding-bottom: 4px; }
        .fc .fc-more-link {
            font-size: .68rem !important; font-weight: 700 !important;
            color: #667eea !important; padding: 1px 6px !important;
            border-radius: 10px !important; background: #eef0fb !important;
        }
        .fc .fc-more-link:hover { background: #e0e7ff !important; }

        /* ── Print Styles ────────────────────────────────────────── */
        @@media print {
            .emr-topbar, .emr-footer, .roster-toolbar,
            .fc-toolbar, #rosterTooltip, #slotsModal,
            #btnToggleCompact, #btnPrint { display: none !important; }
            .roster-page  { height: auto !important; }
            .calendar-wrap { border: none !important; box-shadow: none !important; }
            .fc .fc-daygrid-day-frame { min-height: 60px !important; }
            body { background: #fff !important; }
        }
    </style>
}

<div class="roster-page" id="rosterPage">

    <!-- ── Compact Toolbar ─────────────────────────────────────────────── -->
    <div class="roster-toolbar" id="rosterToolbar">
        <span class="toolbar-label">
            <i class="bi bi-calendar2-heart text-primary"></i> Doctor Roster
        </span>
        <div class="toolbar-divider"></div>
        <span class="toolbar-label"><i class="bi bi-grid-1x2 me-1"></i>Speciality:</span>
        <div class="toolbar-select-wrap">
            <select id="ddlSpecialty" class="form-select form-select-sm s2-search">
                <option value="">— All Specialities —</option>
                @{
                    var specialities = ViewBag.Specialities as IEnumerable<EMR.Web.Models.Entities.DoctorSpecialityMaster>;
                    if (specialities != null)
                    {
                        foreach (var sp in specialities)
                        {
                            <option value="@sp.SpecialityId">@sp.SpecialityName</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="toolbar-divider"></div>
        <span class="toolbar-label"><i class="bi bi-person-badge me-1"></i>Doctor:</span>
        <div class="toolbar-select-wrap">
            <select id="ddlDoctor" class="form-select form-select-sm s2-search">
                <option value="">— All Doctors —</option>
                @if (doctors != null)
                {
                    foreach (var doc in doctors)
                    {
                        <option value="@doc.DoctorId">@doc.FullName</option>
                    }
                }
            </select>
        </div>
        <div class="toolbar-divider"></div>
        <div class="toolbar-legends">
            <span class="legend-pill lp-avail"><span class="dot" style="background:linear-gradient(135deg,#667eea,#764ba2)"></span>Available</span>
            <span class="legend-pill lp-booked"><span class="dot" style="background:linear-gradient(135deg,#11998e,#38ef7d)"></span>Has Bookings</span>
            <span class="legend-pill lp-full"><span class="dot" style="background:linear-gradient(135deg,#f093fb,#f5576c)"></span>Fully Booked</span>
            <span class="legend-pill lp-leave"><span class="dot" style="background:linear-gradient(135deg,#ffecd2,#fcb69f)"></span>Leave</span>
        </div>
        <div class="toolbar-divider"></div>
        <div class="d-flex align-items-center gap-2" style="flex-shrink:0">
            <button id="btnToggleCompact" class="btn-compact" title="Toggle compact / expand all events">
                <i class="bi bi-arrows-expand"></i>Expand All
            </button>
            <button id="btnPrint" class="btn-compact" onclick="window.print()" title="Print roster (Ctrl+P)">
                <i class="bi bi-printer"></i>Print
            </button>
        </div>
    </div>

    <!-- ── Calendar Card ───────────────────────────────────────────────── -->
    <div class="calendar-wrap" id="calendarWrap">
        <!-- Loading overlay -->
        <div id="loadingIndicator" class="roster-loading d-none">
            <div class="spinner-ring"></div>
            <p class="text-muted fw-medium mb-0 small">Loading schedules…</p>
        </div>

        <!-- Empty state overlay -->
        <div id="emptyState" class="empty-state d-none">
            <div class="es-icon"><i class="bi bi-calendar2-week"></i></div>
            <h6 class="fw-bold mb-1" style="color:#1e293b">No Schedules Found</h6>
            <p class="text-muted mb-0 small">No roster schedules are available at this time.</p>
        </div>

        <!-- Calendar -->
        <div id='calendar'></div>
    </div>
</div>

<!-- ── Available Slots Modal ─────────────────────────────────────────── -->
<div class="modal fade" id="slotsModal" tabindex="-1" aria-labelledby="slotsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header">
                <h5 class="modal-title" id="slotsModalLabel">
                    <i class="bi bi-calendar-check me-2"></i>Available Slots
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-4 pb-3 border-bottom">
                    <div>
                        <h5 class="fw-bold mb-1" id="lblDoctorName" style="color:#667eea">Dr. Name</h5>
                        <div class="d-flex align-items-center gap-3 text-muted small mt-1">
                            <span><i class="bi bi-geo-alt-fill text-danger me-1"></i><span id="lblRoomName">Room</span></span>
                            <span><i class="bi bi-calendar-event text-secondary me-1"></i><span id="lblSelectedDate">Date</span></span>
                        </div>
                    </div>
                    <span class="badge rounded-pill px-3 py-2 fs-6" style="background:linear-gradient(135deg,#667eea,#764ba2);color:#fff">
                        <i class="bi bi-clock-history me-1"></i><span id="lblScheduleTime">09:00 - 13:00</span>
                    </span>
                </div>

                <div id="slotsLoading" class="text-center py-5 d-none">
                    <div class="spinner-ring" style="margin:0 auto 14px"></div>
                    <p class="text-muted fw-medium mb-0">Fetching available slots…</p>
                </div>

                <div id="slotsError" class="alert alert-danger border-0 rounded-3 d-none mb-0"></div>
                <div id="slotsException" class="alert alert-warning border-0 rounded-3 d-none mb-0">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i><span id="slotsExceptionMsg"></span>
                </div>

                <div id="slotsContainer" class="row g-3"></div>
            </div>
        </div>
    </div>
</div>

<!-- ── Roster Booking Tooltip ────────────────────────────────────────── -->
<div id="rosterTooltip" role="tooltip">
    <div class="rt-header">
        <span class="rt-date" id="rtDate">—</span>
        <span class="rt-count" id="rtCount">0 Bookings</span>
    </div>
    <div class="rt-body" id="rtBody">
        <div class="rt-empty"><i class="bi bi-calendar2 me-1"></i>No bookings for this date</div>
    </div>
    <div class="rt-footer" id="rtFooter"></div>
    <button class="rt-book-btn" id="rtBookBtn" style="display:none">
        <i class="bi bi-lightning-charge-fill"></i> Book Now
    </button>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function () {

        // ── Compute page offset once (navbar + container padding) ────────
        function computeOffset() {
            const header = document.querySelector('header.emr-topbar');
            const footer = document.querySelector('footer.emr-footer');
            const toolbar = document.getElementById('rosterToolbar');
            const page = document.getElementById('rosterPage');
            const headerH = header ? header.offsetHeight : 58;
            const footerH = footer ? footer.offsetHeight : 0;
            // container py-3 = 16px top+bottom = 32px, plus toolbar + gap
            const containerPadV = 16 + 10; // py-3 top + gap below toolbar approx
            const toolbarH = toolbar ? toolbar.offsetHeight : 52;
            const offset = headerH + footerH + containerPadV + toolbarH + 20;
            document.documentElement.style.setProperty('--roster-offset', offset + 'px');
        }
        computeOffset();
        window.addEventListener('resize', computeOffset);

        // ── Select2 ──────────────────────────────────────────────────────
        $('.s2-search').select2({ theme: 'bootstrap-5', width: '100%' });

        // ── FullCalendar Setup ───────────────────────────────────────────
        const calendarEl = document.getElementById('calendar');
        // Restore last used view from localStorage
        const savedView = localStorage.getItem('rosterCalView') || 'dayGridMonth';
        let isCompact   = localStorage.getItem('rosterCompact') !== 'false'; // default compact=true

        const calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: savedView,
            headerToolbar: {
                left:   'prev,next today',
                center: 'title',
                right:  'dayGridMonth,timeGridWeek,listMonth'
            },
            themeSystem:   'bootstrap5',
            height:        '100%',
            expandRows:    true,
            nowIndicator:  true,
            dayMaxEvents:  isCompact ? 3 : false,
            moreLinkClick: 'popover',
            slotMinTime:   '07:00:00',
            slotMaxTime:   '21:00:00',
            // Persist view selection
            viewDidMount: function (info) {
                localStorage.setItem('rosterCalView', info.view.type);
            },
            // Rich event content for week / time-grid views
            eventContent: function (info) {
                const vt = calendar.view.type;
                if (vt === 'timeGridWeek' || vt === 'timeGridDay') {
                    const p = info.event.extendedProps;
                    const room = p.roomName ? `<div class="ev-sub"><i class="bi bi-geo-alt me-1"></i>${p.roomName}</div>` : '';
                    const cnt  = p.evClass === 'ev-booked' ? `<div class="ev-sub"><i class="bi bi-people me-1"></i>${p.bookingCount || ''} bkd</div>` : '';
                    return { html: `<div class="ev-custom"><div class="ev-title">${info.event.title}</div>${room}${cnt}</div>` };
                }
                return true; // default render for month/list
            },
            // Badge on day-number cells
            dayCellDidMount: function (info) {
                info.el.dataset.date = fmtDate(info.date);
            },
            eventClick:       function (info) { handleEventClick(info.event); },
            eventMouseEnter:  function (info) {
                if (!info.event.extendedProps.isException)
                    showRosterTooltip(info.event, info.jsEvent);
            },
            eventMouseLeave:  function () { hideRosterTooltip(); },
            eventDidMount:    function (info) {
                const props = info.event.extendedProps;
                const cls = props.evClass;
                if (cls) info.el.classList.add(cls);

                // Apply dynamic doctor-wise left border
                if (!props.isException) {
                    const grad = getDoctorGradient(props.doctorId);
                    const matches = grad.bg.match(/#[0-9a-fA-F]{6}/g);
                    const borderColor = matches ? matches[0] : '#667eea';
                    info.el.style.setProperty('border-left', `5px solid ${borderColor}`, 'important');
                }

                // Capacity bar
                if (!props.isException) {
                    const cnt = props.bookingCount || 0;
                    const max = props.maxBookings  || 10;
                    const pct = Math.min(Math.round((cnt / max) * 100), 100);
                    const barColor = pct === 0 ? 'rgba(255,255,255,.4)' :
                                     pct >= 90 ? '#f5576c' :
                                     pct >= 50 ? '#f59e0b' : '#38ef7d';
                    const bar = document.createElement('div');
                    bar.className = 'ev-bar';
                    bar.innerHTML = `<div class="ev-bar-fill" style="width:${pct}%;background:${barColor}"></div>`;
                    info.el.appendChild(bar);
                }
            }
        });
        calendar.render();

        // ── Compact / Expand toggle ───────────────────────────────────────
        const btnCompact = document.getElementById('btnToggleCompact');
        function applyCompactMode() {
            btnCompact.innerHTML = isCompact
                ? '<i class="bi bi-arrows-expand"></i>Expand All'
                : '<i class="bi bi-arrows-collapse"></i>Compact';
            btnCompact.classList.toggle('active', !isCompact);
            calendar.setOption('dayMaxEvents', isCompact ? 3 : false);
        }
        applyCompactMode();
        btnCompact.addEventListener('click', () => {
            isCompact = !isCompact;
            localStorage.setItem('rosterCompact', isCompact);
            applyCompactMode();
        });

        // ── Keyboard shortcuts: ← → for nav, T for today ─────────────────
        document.addEventListener('keydown', function (e) {
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
            if (e.key === 'ArrowLeft')  { calendar.prev();  }
            if (e.key === 'ArrowRight') { calendar.next();  }
            if (e.key === 't' || e.key === 'T') { calendar.today(); }
        });

        let currentSchedules = [];
        let currentExceptions = [];
        let bookingCountCache = {};
        let tooltipCache      = {};
        const slotsModal = new bootstrap.Modal(document.getElementById('slotsModal'));

        // ── Load Roster ──────────────────────────────────────────────────
        // doctorId and specialityId are both optional; pass whatever is selected
        async function loadRoster(doctorId, specialityId) {
            tooltipCache = {};
            bookingCountCache = {};

            $('#emptyState').addClass('d-none');
            $('#loadingIndicator').removeClass('d-none');

            try {
                let url = `@Url.Action("GetDoctorSchedules", "DoctorRoster")?`;
                if (doctorId)    url += `doctorId=${doctorId}&`;
                if (specialityId) url += `specialityId=${specialityId}&`;

                const response = await fetch(url);
                const data = await response.json();
                if (data.error) { alert('Error: ' + data.error); return; }

                currentSchedules = data.schedules || [];
                currentExceptions = data.exceptions || [];

                if (doctorId) {
                    await preloadBookingCounts(doctorId);
                } else {
                    const uniqueDoctorIds = [...new Set(currentSchedules.map(s => s.doctorId).filter(Boolean))];
                    await Promise.all(uniqueDoctorIds.map(dId => preloadBookingCounts(dId)));
                }

                renderCalendarEvents();
                $('#loadingIndicator').addClass('d-none');
                calendar.updateSize();
            } catch (err) {
                console.error(err);
                alert('Failed to load doctor roster.');
                $('#loadingIndicator').addClass('d-none');
                $('#emptyState').removeClass('d-none');
            }
        }

        // Load all schedules on startup
        loadRoster('', '');

        // ── Speciality change → repopulate doctors + reload roster ───────
        $('#ddlSpecialty').on('change', async function () {
            const deptId = $(this).val();

            // Repopulate doctor dropdown
            const $doc = $('#ddlDoctor');
            $doc.val('').trigger('change'); // reset selection
            $doc.find('option:not(:first)').remove(); // clear old options

            if (deptId) {
                try {
                    const res  = await fetch(`@Url.Action("GetDoctorsBySpecialty", "DoctorRoster")?specialityId=${deptId}`);
                    const docs = await res.json();
                    docs.forEach(d => {
                        $doc.append(new Option(d.name, d.id));
                    });
                } catch (e) { console.error('Failed to load doctors by specialty', e); }
            } else {
                // Restore all doctors from the server-rendered list
                const allDoctors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    (ViewBag.Doctors as IEnumerable<(int DoctorId, string FullName, int? PrimarySpecialityId, string Gender)>)
                        ?.Select(d => new { id = d.DoctorId, name = d.FullName })
                    ?? Enumerable.Empty<object>()
                ));
                allDoctors.forEach(d => {
                    $doc.append(new Option(d.name, d.id));
                });
            }

            // Reload calendar for the selected speciality (no doctor filter)
            loadRoster('', deptId);
        });

        // ── Doctor change ────────────────────────────────────────────────
        $('#ddlDoctor').on('change', function () {
            const doctorId    = $(this).val();
            const specialityId = $('#ddlSpecialty').val();
            loadRoster(doctorId, specialityId);
        });

        // ── Preload Booking Counts ───────────────────────────────────────
        async function preloadBookingCounts(doctorId) {
            const today = new Date();
            const start = new Date(today.getFullYear(), today.getMonth() - 1, 1);
            const end   = new Date(today.getFullYear(), today.getMonth() + 6, 0);

            const dates = [];
            const docId = Number(doctorId);
            currentSchedules.filter(s => s.doctorId === docId).forEach(sch => {
                let jsDay   = sch.dayOfWeek === 7 ? 0 : sch.dayOfWeek;
                let effFrom = new Date(sch.effectiveFrom);
                let effTo   = sch.effectiveTo ? new Date(sch.effectiveTo) : end;
                for (let d = new Date(start); d <= end; d.setDate(d.getDate() + 1)) {
                    if (d.getDay() === jsDay && d >= effFrom && d <= effTo) {
                        const ds = fmtDate(d);
                        if (!dates.includes(ds)) dates.push(ds);
                    }
                }
            });

            const subset = dates.sort().slice(0, 60);
            await Promise.all(subset.map(async ds => {
                const cacheKey = `${doctorId}_${ds}`;
                try {
                    const resp = await fetch(`@Url.Action("GetDateBookings", "DoctorRoster")?doctorId=${doctorId}&date=${ds}`);
                    const data = await resp.json();
                    const rawBookings = data.bookings || [];
                    const activeBookings = rawBookings.filter(b => (b.status || '') !== 'Completed');
                    tooltipCache[cacheKey] = activeBookings;
                    bookingCountCache[cacheKey] = activeBookings.length;
                } catch { bookingCountCache[cacheKey] = 0; }
            }));
        }

        function fmtDate(d) {
            return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
        }

        function getDoctorGradient(doctorId) {
            const gradients = [
                { bg: 'linear-gradient(135deg, #4f46e5, #7c3aed)', text: '#ffffff' }, // Indigo/Violet
                { bg: 'linear-gradient(135deg, #059669, #0d9488)', text: '#ffffff' }, // Emerald/Teal
                { bg: 'linear-gradient(135deg, #e11d48, #db2777)', text: '#ffffff' }, // Rose/Red
                { bg: 'linear-gradient(135deg, #d97706, #ea580c)', text: '#ffffff' }, // Amber/Orange
                { bg: 'linear-gradient(135deg, #0284c7, #2563eb)', text: '#ffffff' }, // Cyan/Blue
                { bg: 'linear-gradient(135deg, #c026d3, #8b5cf6)', text: '#ffffff' }, // Magenta/Purple
                { bg: 'linear-gradient(135deg, #06b6d4, #0891b2)', text: '#ffffff' }, // Sky/Teal
                { bg: 'linear-gradient(135deg, #16a34a, #15803d)', text: '#ffffff' }, // Forest/Green
                { bg: 'linear-gradient(135deg, #701a75, #4a044e)', text: '#ffffff' }, // Plum/Grape
                { bg: 'linear-gradient(135deg, #475569, #1e293b)', text: '#ffffff' }, // Slate/Navy
                { bg: 'linear-gradient(135deg, #9a3412, #7c2d12)', text: '#ffffff' }, // Bronze/Brown
                { bg: 'linear-gradient(135deg, #ec4899, #f43f5e)', text: '#ffffff' }  // Lavender/Pink
            ];
            const idx = Math.abs(parseInt(doctorId, 10) || 0) % gradients.length;
            return gradients[idx];
        }

        // ── Render Events ────────────────────────────────────────────────
        function renderCalendarEvents() {
            calendar.removeAllEvents();
            const events = [];
            const today   = new Date(); today.setHours(0,0,0,0);
            const startR  = new Date(today.getFullYear(), today.getMonth() - 1, 1);
            const endR    = new Date(today.getFullYear(), today.getMonth() + 6, 0);
            const selectedDoctorId = $('#ddlDoctor').val();

            currentSchedules.forEach(sch => {
                let jsDay   = sch.dayOfWeek === 7 ? 0 : sch.dayOfWeek;
                let effFrom = new Date(sch.effectiveFrom);
                let effTo   = sch.effectiveTo ? new Date(sch.effectiveTo) : endR;

                for (let d = new Date(startR); d <= endR; d.setDate(d.getDate() + 1)) {
                    if (d.getDay() !== jsDay || d < effFrom || d > effTo) continue;

                    const dateStr    = fmtDate(d);
                    const cacheKey   = `${sch.doctorId}_${dateStr}`;
                    const exception  = currentExceptions.find(e => e.doctorId === sch.doctorId && e.exceptionDate.startsWith(dateStr));
                    const count      = bookingCountCache[cacheKey] ?? null;

                    if (exception) {
                        const exceptionTitle = selectedDoctorId
                            ? `⚠ ${exception.reason || 'Leave / Unavailable'}`
                            : `⚠ ${sch.doctorName || 'Doctor'}: ${exception.reason || 'Leave'}`;
                        events.push({
                            title: exceptionTitle,
                            start: dateStr, allDay: true,
                            extendedProps: {
                                isException: true,
                                reason: exception.reason,
                                evClass: 'ev-exception',
                                doctorId: sch.doctorId,
                                doctorName: sch.doctorName
                            }
                        });
                    } else {
                        let evClass    = 'ev-available';
                        let countLabel = '';
                        if (count !== null && count > 0) {
                            evClass    = 'ev-booked';
                            countLabel = ` · ${count} bkd`;
                        }

                        // Fully booked check: if bookings equal or exceed maxBookings
                        const max = sch.maxBookings || 10;
                        if (count !== null && count >= max) {
                            evClass = 'ev-full';
                        }

                        const timeLabel  = `${sch.startTime.substring(0,5)}–${sch.endTime.substring(0,5)}`;
                        const eventTitle = selectedDoctorId
                            ? `🕐 ${timeLabel}${countLabel}`
                            : `🕐 ${sch.doctorName || 'Doctor'} (${timeLabel})${countLabel}`;

                        events.push({
                            title: eventTitle,
                            start: `${dateStr}T${sch.startTime}`,
                            end:   `${dateStr}T${sch.endTime}`,
                            extendedProps: {
                                isException:   false,
                                evClass,
                                scheduleId:    sch.scheduleId,
                                roomName:      sch.roomName || 'Not Assigned',
                                doctorId:      sch.doctorId,
                                doctorName:    sch.doctorName,
                                date:          dateStr,
                                timeString:    timeLabel,
                                bookingCount:  count || 0,
                                maxBookings:   max
                            }
                        });
                    }
                }
            });

            calendar.addEventSource(events);
            // Update per-day booking badges after events are rendered
            setTimeout(updateDayBadges, 100);
        }

        // ── Event Click → Show Slots Modal ──────────────────────────────
        async function handleEventClick(event) {
            if (event.extendedProps.isException) return;

            const props      = event.extendedProps;

            // Validation: Cannot book for past dates
            const clickedDate = new Date(props.date + 'T00:00:00');
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            if (clickedDate < today) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Past Date',
                    text: 'New bookings cannot be created for past dates.',
                    confirmButtonColor: '#667eea'
                });
                return;
            }

            const doctorName = props.doctorName || $('#ddlDoctor option:selected').text();

            $('#lblDoctorName').text(doctorName);
            $('#lblRoomName').text(props.roomName);
            const dateObj = new Date(props.date);
            $('#lblSelectedDate').text(dateObj.toLocaleDateString('en-GB', { weekday:'short', day:'2-digit', month:'short', year:'numeric' }));
            $('#lblScheduleTime').text(props.timeString);

            $('#slotsContainer').empty();
            $('#slotsError').addClass('d-none');
            $('#slotsException').addClass('d-none');
            $('#slotsLoading').removeClass('d-none');
            slotsModal.show();

            try {
                const response = await fetch(`@Url.Action("GetAvailableSlots", "OPD")?doctorId=${props.doctorId}&date=${props.date}`);
                const result   = await response.json();
                $('#slotsLoading').addClass('d-none');

                if (result.hasException) {
                    $('#slotsExceptionMsg').text(result.exceptionReason || 'Doctor is unavailable on this date.');
                    $('#slotsException').removeClass('d-none');
                    return;
                }
                if (!result.slots || result.slots.length === 0) {
                    $('#slotsError').text('No slots generated for this schedule.').removeClass('d-none');
                    return;
                }

                result.slots.filter(s => s.scheduleId === props.scheduleId).forEach(slot => {
                    const col      = document.createElement('div');
                    col.className  = 'col-6 col-md-4 col-lg-3';
                    const isFull   = !slot.isAvailable;
                    const pct      = Math.round((slot.bookedCount / slot.maxPerSlot) * 100);
                    const barColor = isFull ? '#f5576c' : pct > 50 ? '#f59e0b' : '#11998e';
                    const bookUrl  = `@Url.Action("PatientRegistration", "OPD")?doctorId=${props.doctorId}&date=${props.date}&scheduleId=${slot.scheduleId}&time=${slot.slotTime}`;

                    col.innerHTML = `
                        <button type="button"
                            class="btn w-100 slot-btn p-3 text-start h-100 d-flex flex-column justify-content-center shadow-sm border
                                   ${isFull ? '' : 'slot-available'}"
                            ${isFull ? 'disabled' : `onclick="window.location.href='${bookUrl}'"`}>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold fs-6 ${isFull ? 'text-muted' : ''}" style="${isFull ? '' : 'color:#667eea'}">
                                    <i class="bi bi-clock me-1 small"></i>${slot.slotTime}
                                </span>
                                ${isFull
                                    ? `<span class="badge" style="background:#f5576c;color:#fff;border-radius:8px;font-size:.7rem">FULL</span>`
                                    : `<i class="bi bi-arrow-right-circle" style="color:#667eea;opacity:.6"></i>`}
                            </div>
                            <div class="progress mb-1" style="height:5px;border-radius:4px">
                                <div class="progress-bar" role="progressbar"
                                     style="width:${pct}%;background:${barColor};border-radius:4px"></div>
                            </div>
                            <small class="${isFull ? 'text-muted' : 'fw-semibold'}" style="${isFull ? '' : 'color:#11998e'}">
                                ${slot.bookedCount} / ${slot.maxPerSlot} Booked
                            </small>
                        </button>`;
                    $('#slotsContainer').append(col);
                });

                if ($('#slotsContainer').children().length === 0) {
                    $('#slotsError').text('No slots found for this specific schedule block.').removeClass('d-none');
                }
            } catch (err) {
                $('#slotsLoading').addClass('d-none');
                $('#slotsError').text('Failed to fetch available slots.').removeClass('d-none');
            }
        }

        // ── Update Day Booking Badges ─────────────────────────────────────
        function updateDayBadges() {
            // Sum bookings per calendar date across all doctors
            const totals = {};
            Object.entries(bookingCountCache).forEach(([key, cnt]) => {
                const parts = key.split('_');
                const date  = parts.slice(1).join('_'); // handles doctorId_YYYY-MM-DD
                if (cnt > 0) totals[date] = (totals[date] || 0) + cnt;
            });
            // Inject badges into day cells
            document.querySelectorAll('.fc-daygrid-day').forEach(cell => {
                const date = cell.dataset.date || cell.getAttribute('data-date');
                if (!date) return;
                // Remove existing badge
                const old = cell.querySelector('.day-bkd-badge');
                if (old) old.remove();
                const total = totals[date];
                if (total) {
                    const badge = document.createElement('span');
                    badge.className = 'day-bkd-badge' + (total >= 10 ? ' many' : '');
                    badge.title     = `${total} booking${total > 1 ? 's' : ''} on this day`;
                    badge.innerHTML = `<i class="bi bi-people-fill" style="font-size:.55rem"></i>${total}`;
                    const numEl = cell.querySelector('.fc-daygrid-day-number');
                    if (numEl) numEl.appendChild(badge);
                }
            });
        }

        // ── Hover Tooltip ────────────────────────────────────────────────
        const tooltip  = document.getElementById('rosterTooltip');
        const rtDate   = document.getElementById('rtDate');
        const rtCount  = document.getElementById('rtCount');
        const rtBody   = document.getElementById('rtBody');
        const rtFooter = document.getElementById('rtFooter');
        const rtBookBtn = document.getElementById('rtBookBtn');
        let hideTimer       = null;
        let tooltipPinned   = false;
        let currentTooltipEvent = null; // stores the FC event for Book Now

        async function showRosterTooltip(event, jsEvent) {
            clearTimeout(hideTimer);
            currentTooltipEvent = event;  // store for Book Now
            const props    = event.extendedProps;
            const doctorId = Number($('#ddlDoctor').val()) || props.doctorId;
            const dateStr  = props.date;

            // Only reposition if tooltip is not already visible (pinned by user)
            if (!tooltip.classList.contains('show')) {
                positionTooltip(jsEvent);
            }

            const dateObj = new Date(dateStr + 'T00:00:00');
            rtDate.textContent  = dateObj.toLocaleDateString('en-GB', { weekday:'short', day:'2-digit', month:'short', year:'numeric' });
            rtCount.textContent = 'Loading…';
            rtBody.innerHTML    = '<div class="rt-empty"><div class="spinner-border spinner-border-sm me-2" style="color:#667eea"></div>Loading…</div>';
            rtFooter.innerHTML  = '';
            
            // Validation: Check if past date
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const isPast = dateObj < today;

            if (isPast) {
                rtBookBtn.style.display = 'none';
            } else {
                // Show Book Now button (disabled while loading)
                rtBookBtn.style.display = '';
                rtBookBtn.disabled = true;
                rtBookBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Loading…';
            }
            
            tooltip.classList.add('show');

            const cacheKey = `${doctorId}_${dateStr}`;
            if (tooltipCache[cacheKey]) { renderTooltipData(tooltipCache[cacheKey]); return; }

            try {
                const resp = await fetch(`@Url.Action("GetDateBookings", "DoctorRoster")?doctorId=${doctorId}&date=${dateStr}`);
                const data = await resp.json();
                
                // Filter out Completed bookings
                const activeBookings = (data.bookings || []).filter(b => (b.status || '') !== 'Completed');
                
                tooltipCache[cacheKey]      = activeBookings;
                bookingCountCache[cacheKey] = activeBookings.length;
                renderTooltipData(tooltipCache[cacheKey]);
            } catch {
                rtBody.innerHTML = '<div class="rt-empty text-danger"><i class="bi bi-exclamation-circle me-1"></i>Failed to load</div>';
                rtCount.textContent = '—';
                rtBookBtn.style.display = 'none';
            }
        }

        function renderTooltipData(bookings) {
            const count = bookings.length;
            rtCount.textContent = count === 0 ? 'No Bookings' : `${count} Booking${count > 1 ? 's' : ''}`;

            if (count === 0) {
                rtBody.innerHTML   = '<div class="rt-empty"><i class="bi bi-calendar2 me-1"></i>No bookings for this date</div>';
                rtFooter.innerHTML = '';
                return;
            }

            let html = '';
            bookings.forEach(b => {
                const initials    = (b.patientName || '?').split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
                const slotLabel   = b.appointmentTime ? formatTime(b.appointmentTime) : '—';
                const statusClass = b.status === 'Registered' ? 'rt-badge-r' : b.status === 'Completed' ? 'rt-badge-c' : 'rt-badge-x';
                const amount      = (b.totalAmount || 0).toFixed(2);
                html += `
                    <div class="rt-item">
                        <div class="rt-avatar">${initials}</div>
                        <div class="rt-info">
                            <div class="rt-name">${b.patientName || '—'}</div>
                            <div class="rt-sub">
                                <span class="badge ${statusClass} rounded-pill px-2 py-0" style="font-size:.67rem">${b.status || 'Unknown'}</span>
                                &nbsp;${b.patientCode || ''} &bull; ${b.phoneNumber || '—'}
                            </div>
                            <div class="rt-sub mt-1"><i class="bi bi-bag me-1"></i>${b.serviceTypesSummary || 'Consulting'} — ₹${amount}</div>
                        </div>
                        <div class="rt-slot"><i class="bi bi-clock me-1"></i>${slotLabel}</div>
                    </div>`;
            });
            rtBody.innerHTML = html;

            const total = bookings.reduce((s, b) => s + (b.totalAmount || 0), 0);
            rtFooter.innerHTML = `
                <span><i class="bi bi-people me-1"></i>${count} patient${count > 1 ? 's' : ''}</span>
                <span class="fw-semibold" style="color:#667eea">₹${total.toFixed(2)}</span>`;
            
            // Enable Book Now button if not past
            if (rtBookBtn.style.display !== 'none') {
                rtBookBtn.disabled = false;
                rtBookBtn.innerHTML = '<i class="bi bi-lightning-charge-fill"></i> Book Now';
            }
        }

        function formatTime(ts) {
            if (!ts) return '—';
            const p = ts.split(':');
            let h = parseInt(p[0], 10);
            const m = p[1] || '00';
            const ap = h >= 12 ? 'PM' : 'AM';
            h = h % 12 || 12;
            return `${h}:${m} ${ap}`;
        }

        function positionTooltip(e) {
            const mg = 10, tw = 340, th = 360;
            let x = e.clientX + mg, y = e.clientY + mg;
            if (x + tw > window.innerWidth)  x = e.clientX - tw - mg;
            if (y + th > window.innerHeight) y = e.clientY - th - mg;
            tooltip.style.left = x + 'px';
            tooltip.style.top  = y + 'px';
        }

        function scheduleHide() {
            // Give 800ms grace period – enough time to move cursor from event into tooltip
            hideTimer = setTimeout(() => {
                if (!tooltipPinned) tooltip.classList.remove('show');
            }, 800);
        }

        function hideRosterTooltip() {
            scheduleHide();
        }

        // ── Tooltip stays alive while mouse is inside it ──────────────────
        tooltip.addEventListener('mouseenter', () => {
            tooltipPinned = true;
            clearTimeout(hideTimer);
        });
        tooltip.addEventListener('mouseleave', () => {
            tooltipPinned = false;
            scheduleHide();
        });

        // ── Book Now button – opens slots modal directly ──────────────────
        rtBookBtn.addEventListener('click', () => {
            if (!currentTooltipEvent) return;
            // Hide tooltip immediately
            clearTimeout(hideTimer);
            tooltipPinned = false;
            tooltip.classList.remove('show');
            rtBookBtn.style.display = 'none';
            // Open slots modal for this event
            handleEventClick(currentTooltipEvent);
        });

        // Also re-hide book button when tooltip fades out
        tooltip.addEventListener('transitionend', () => {
            if (!tooltip.classList.contains('show')) {
                rtBookBtn.style.display = 'none';
            }
        });
    });
    </script>
}
