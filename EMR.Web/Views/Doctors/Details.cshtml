@model EMR.Web.Models.ViewModels.DoctorDetailsViewModel
@{
    ViewData["Title"] = "Doctor Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-0 fw-bold">Doctor Details</h1>
        <small class="text-muted">Viewing details for @Model.FullName</small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.DoctorId" class="btn btn-primary btn-sm px-3">
            <i class="bi bi-pencil me-1"></i>Edit Profile
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-3">
    @* ── Left Side: Personal & Professional Profile ── *@
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-3" style="border-radius: 8px;">
            <div class="card-header bg-white py-2 px-3 border-bottom-0 d-flex align-items-center">
                <i class="bi bi-person-vcard text-primary fs-5 me-2"></i>
                <h6 class="fw-bold mb-0 text-dark">Personal & Professional Profile</h6>
            </div>
            <div class="card-body pt-0 px-3 pb-3">
                <div class="row g-2">
                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">Doctor Name:</div>
                        <div class="fw-bold text-dark text-truncate">@Model.FullName</div>
                    </div>
                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">Status:</div>
                        <div>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle py-0.5 px-2 small">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle py-0.5 px-2 small">Inactive</span>
                            }
                        </div>
                    </div>

                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">Email ID:</div>
                        <div class="text-dark text-truncate small">@Model.EmailId</div>
                    </div>
                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">Phone Number:</div>
                        <div class="text-dark small">@Model.PhoneNumber</div>
                    </div>

                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">Gender:</div>
                        <div class="text-dark small">@Model.Gender</div>
                    </div>
                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">Date of Birth:</div>
                        <div class="text-dark small">@(Model.DateOfBirth?.ToString("dd MMM yyyy") ?? "-")</div>
                    </div>

                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">Primary Speciality:</div>
                        <div><span class="badge bg-primary py-1 px-2 small">@Model.PrimarySpecialityName</span></div>
                    </div>
                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">Secondary Speciality:</div>
                        <div class="text-dark small">@(string.IsNullOrWhiteSpace(Model.SecondarySpecialityName) ? "-- none --" : Model.SecondarySpecialityName)</div>
                    </div>

                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">License / MMC:</div>
                        <div class="text-dark font-monospace small">@(string.IsNullOrWhiteSpace(Model.MedicalLicenseNo) ? "-" : Model.MedicalLicenseNo)</div>
                    </div>
                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">Joining Date:</div>
                        <div class="text-dark small">@(Model.JoiningDate?.ToString("dd MMM yyyy") ?? "-")</div>
                    </div>

                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">Created On:</div>
                        <div class="text-muted small">@Model.CreatedDate.ToString("dd MMM yyyy, HH:mm")</div>
                    </div>
                    <div class="col-sm-6 d-flex align-items-center">
                        <div style="min-width: 120px;" class="text-secondary small fw-semibold">Last Modified:</div>
                        <div class="text-muted small">@(Model.ModifiedDate?.ToString("dd MMM yyyy, HH:mm") ?? "-")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Right Side: Mappings & Login Info ── *@
    <div class="col-lg-5">
        @* Mappings Card *@
        <div class="card border-0 shadow-sm mb-3" style="border-radius: 8px;">
            <div class="card-header bg-white py-2 px-3 border-bottom-0 d-flex align-items-center">
                <i class="bi bi-grid text-success fs-5 me-2"></i>
                <h6 class="fw-bold mb-0 text-dark">Mappings & Departments</h6>
            </div>
            <div class="card-body pt-0 px-3 pb-3">
                <div class="mb-2">
                    <span class="text-secondary small fw-semibold d-block mb-1">Assigned Branches</span>
                    <div class="d-flex flex-wrap gap-1">
                        @if (Model.BranchNames.Any())
                        {
                            foreach (var b in Model.BranchNames)
                            {
                                <span class="badge text-bg-light border px-2 py-1 text-dark small"><i class="bi bi-building me-1 text-primary"></i>@b</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted small fst-italic">No branch mappings found.</span>
                        }
                    </div>
                </div>
                <div>
                    <span class="text-secondary small fw-semibold d-block mb-1">Departments</span>
                    <div class="d-flex flex-wrap gap-1">
                        @if (Model.DepartmentNames.Any())
                        {
                            foreach (var dept in Model.DepartmentNames)
                            {
                                <span class="badge text-bg-light border px-2 py-1 text-dark small"><i class="bi bi-folder-check me-1 text-success"></i>@dept</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted small fst-italic">No departments mapped.</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Login Information Card *@
        <div class="card border-0 shadow-sm" style="border-radius: 8px;">
            <div class="card-header bg-white py-2 px-3 border-bottom-0 d-flex align-items-center">
                <i class="bi bi-shield-lock text-info fs-5 me-2"></i>
                <h6 class="fw-bold mb-0 text-dark">System Login Account</h6>
            </div>
            <div class="card-body pt-0 px-3 pb-3">
                @if (Model.LinkedUserId.HasValue)
                {
                    <div class="row g-2">
                        <div class="col-sm-6 d-flex align-items-center">
                            <span style="min-width: 90px;" class="text-secondary small fw-semibold">Username:</span>
                            <span class="fw-bold text-dark font-monospace small"><i class="bi bi-person-circle text-info me-1"></i>@Model.LoginUsername</span>
                        </div>
                        <div class="col-sm-6 d-flex align-items-center">
                            <span style="min-width: 90px;" class="text-secondary small fw-semibold">Status:</span>
                            @if (Model.IsLoginActive)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle py-0.5 px-2 small">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle py-0.5 px-2 small">Disabled</span>
                            }
                        </div>
                        <div class="col-12 mt-2">
                            <div class="alert alert-info py-1.5 px-2 mb-0 small border-0 bg-info-subtle text-info-emphasis rounded-3" style="font-size: 0.75rem;">
                                <i class="bi bi-info-circle-fill me-1"></i>
                                Password & roles can be changed from the <strong>User Master</strong> page.
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-3 text-muted">
                        <i class="bi bi-shield-slash fs-4 mb-1 opacity-50 text-secondary"></i>
                        <p class="mb-0 small">No login account linked for this doctor.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ── Full Width: Consulting Fees ── *@
@if (Model.ConsultingFees.Any())
{
    <div class="card border-0 shadow-sm mt-3 mb-3" style="border-radius: 8px;">
        <div class="card-header bg-white py-2 px-3 border-bottom-0 d-flex align-items-center">
            <i class="bi bi-currency-rupee text-warning fs-5 me-2"></i>
            <h6 class="fw-bold mb-0 text-dark">Consulting Fees & Mapping</h6>
        </div>
        <div class="card-body pt-0 px-3 pb-3">
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 150px; font-size: 0.85rem; padding: 4px 8px;">Item Code</th>
                            <th style="font-size: 0.85rem; padding: 4px 8px;">Service Name</th>
                            <th class="text-end" style="width: 200px; font-size: 0.85rem; padding: 4px 8px;">Charges (₹)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fee in Model.ConsultingFees)
                        {
                            <tr>
                                <td style="padding: 4px 8px;">
                                    <span class="badge text-bg-light border font-monospace text-dark px-2 py-0.5 small">@fee.ItemCode</span>
                                </td>
                                <td class="fw-semibold text-dark small" style="padding: 4px 8px;">@fee.ItemName</td>
                                <td class="text-end fw-bold text-success small" style="padding: 4px 8px;">₹ @fee.ItemCharges.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
