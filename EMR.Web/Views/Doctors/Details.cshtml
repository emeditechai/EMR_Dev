@model EMR.Web.Models.ViewModels.DoctorDetailsViewModel
@{
    ViewData["Title"] = "Doctor Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 fw-bold">Doctor Details</h1>
        <small class="text-muted">Viewing details for @Model.FullName</small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.DoctorId" class="btn btn-primary px-3">
            <i class="bi bi-pencil me-1"></i>Edit Profile
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary px-3">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    @* ── Left Side: Personal & Professional Profile ── *@
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4 h-100" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header bg-white py-3 border-bottom-0 d-flex align-items-center">
                <div class="rounded-circle bg-primary-subtle text-primary p-2 me-3 d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                    <i class="bi bi-person-vcard-fill fs-5"></i>
                </div>
                <h5 class="fw-bold mb-0 text-dark">Personal & Professional Profile</h5>
            </div>
            <div class="card-body pt-1">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1">Doctor Name</label>
                        <span class="fw-bold text-dark fs-5">@Model.FullName</span>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1">Status</label>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                <i class="bi bi-check-circle me-1"></i>Active
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2">
                                <i class="bi bi-slash-circle me-1"></i>Inactive
                            </span>
                        }
                    </div>

                    <div class="col-12"><hr class="text-light my-2" /></div>

                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1"><i class="bi bi-envelope me-1"></i>Email ID</label>
                        <span class="fw-semibold text-dark">@Model.EmailId</span>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1"><i class="bi bi-telephone me-1"></i>Phone Number</label>
                        <span class="fw-semibold text-dark">@Model.PhoneNumber</span>
                    </div>

                    <div class="col-12"><hr class="text-light my-2" /></div>

                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1">Gender</label>
                        <span class="fw-semibold text-dark">@Model.Gender</span>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1">Date of Birth</label>
                        <span class="fw-semibold text-dark">@(Model.DateOfBirth?.ToString("dd MMM yyyy") ?? "-")</span>
                    </div>

                    <div class="col-12"><hr class="text-light my-2" /></div>

                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1">Primary Speciality</label>
                        <span class="badge bg-primary px-3 py-2 fs-6">@Model.PrimarySpecialityName</span>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1">Secondary Speciality</label>
                        <span class="text-dark fw-semibold">@(string.IsNullOrWhiteSpace(Model.SecondarySpecialityName) ? "-- none --" : Model.SecondarySpecialityName)</span>
                    </div>

                    <div class="col-12"><hr class="text-light my-2" /></div>

                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1">Medical License / MMC</label>
                        <span class="text-dark font-monospace fw-semibold">@(string.IsNullOrWhiteSpace(Model.MedicalLicenseNo) ? "-" : Model.MedicalLicenseNo)</span>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1">Joining Date</label>
                        <span class="fw-semibold text-dark">@(Model.JoiningDate?.ToString("dd MMM yyyy") ?? "-")</span>
                    </div>

                    <div class="col-12"><hr class="text-light my-2" /></div>

                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1">Created On</label>
                        <span class="text-muted small">@Model.CreatedDate.ToString("dd MMM yyyy, HH:mm")</span>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-secondary small fw-semibold d-block mb-1">Last Modified</label>
                        <span class="text-muted small">@(Model.ModifiedDate?.ToString("dd MMM yyyy, HH:mm") ?? "-")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Right Side: Mappings & Login Info ── *@
    <div class="col-lg-5">
        @* Mappings Card *@
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header bg-white py-3 border-bottom-0 d-flex align-items-center">
                <div class="rounded-circle bg-success-subtle text-success p-2 me-3 d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                    <i class="bi bi-grid-fill fs-5"></i>
                </div>
                <h5 class="fw-bold mb-0 text-dark">Mappings & Departments</h5>
            </div>
            <div class="card-body pt-1">
                <div class="mb-3">
                    <label class="text-secondary small fw-semibold d-block mb-2">Assigned Branches</label>
                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.BranchNames.Any())
                        {
                            foreach (var b in Model.BranchNames)
                            {
                                <span class="badge text-bg-light border px-3 py-2 text-dark"><i class="bi bi-building me-1 text-primary"></i>@b</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted small fst-italic">No branch mappings found.</span>
                        }
                    </div>
                </div>
                <div>
                    <label class="text-secondary small fw-semibold d-block mb-2">Departments</label>
                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.DepartmentNames.Any())
                        {
                            foreach (var dept in Model.DepartmentNames)
                            {
                                <span class="badge text-bg-light border px-3 py-2 text-dark"><i class="bi bi-folder-check me-1 text-success"></i>@dept</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted small fst-italic">No departments mapped.</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Login Information Card *@
        <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header bg-white py-3 border-bottom-0 d-flex align-items-center">
                <div class="rounded-circle bg-info-subtle text-info p-2 me-3 d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                    <i class="bi bi-shield-lock-fill fs-5"></i>
                </div>
                <h5 class="fw-bold mb-0 text-dark">System Login Account</h5>
            </div>
            <div class="card-body pt-1">
                @if (Model.LinkedUserId.HasValue)
                {
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label class="text-secondary small fw-semibold d-block mb-1">Username</label>
                            <span class="fw-bold text-dark font-monospace"><i class="bi bi-person-circle text-info me-1"></i>@Model.LoginUsername</span>
                        </div>
                        <div class="col-sm-6">
                            <label class="text-secondary small fw-semibold d-block mb-1">Login Status</label>
                            @if (Model.IsLoginActive)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">
                                    <i class="bi bi-check-circle-fill me-1"></i>Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1">
                                    <i class="bi bi-x-circle-fill me-1"></i>Disabled
                                </span>
                            }
                        </div>
                        <div class="col-12 mt-2">
                            <div class="alert alert-info py-2 px-3 mb-0 small border-0 bg-info-subtle text-info-emphasis rounded-3">
                                <i class="bi bi-info-circle-fill me-2"></i>
                                Password and roles management can be handled via the <strong>User Master</strong> page.
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-shield-slash fs-2 mb-2 opacity-50 text-secondary"></i>
                        <p class="mb-0 small">No login account linked for this doctor.</p>
                        <small class="text-muted">Edit profile and toggle "Is Login Required" to create one.</small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ── Full Width: Consulting Fees ── *@
@if (Model.ConsultingFees.Any())
{
    <div class="card border-0 shadow-sm mt-4 mb-4" style="border-radius: 12px; overflow: hidden;">
        <div class="card-header bg-white py-3 border-bottom-0 d-flex align-items-center">
            <div class="rounded-circle bg-warning-subtle text-warning p-2 me-3 d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                <i class="bi bi-currency-rupee fs-5"></i>
            </div>
            <h5 class="fw-bold mb-0 text-dark">Consulting Fees & Mapping</h5>
        </div>
        <div class="card-body pt-1">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 150px;">Item Code</th>
                            <th>Service Name</th>
                            <th class="text-end" style="width: 200px;">Charges (₹)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fee in Model.ConsultingFees)
                        {
                            <tr>
                                <td>
                                    <span class="badge text-bg-light border font-monospace text-dark px-3 py-1">@fee.ItemCode</span>
                                </td>
                                <td class="fw-semibold text-dark">@fee.ItemName</td>
                                <td class="text-end fw-bold text-success fs-6">₹ @fee.ItemCharges.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
