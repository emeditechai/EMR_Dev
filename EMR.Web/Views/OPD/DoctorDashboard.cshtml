        // Dynamic EMR Patient Consultation Implementation
        async function triggerEMRStub() {
            if (!activeOPDServiceId) {
                Swal.fire({
                    icon: 'warning',
                    title: 'No Active Patient',
                    text: 'Please select a patient from the queue and click Start EMR first.'
                });
                return;
            }

            const doctorSelect = document.getElementById('ddlDoctorDashboard');
            if (!doctorSelect || !doctorSelect.value) {
                Swal.fire({
                    icon: 'warning',
                    title: 'No Doctor Selected',
                    text: 'Please select a consulting doctor first.'
                });
                return;
            }

            const doctorId = doctorSelect.value;
            Swal.fire({
                title: 'Loading EMR Template...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            try {
                const res = await fetch(`/OPD/GetPatientConsultationData?opdServiceId=${activeOPDServiceId}&doctorId=${doctorId}`);
                const data = await res.json();
                Swal.close();

                if (!data.success) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'EMR Template Error',
                        text: data.message
                    });
                    return;
                }

                // Populate patient metadata
                $('#emrPatientId').val(data.booking.patientId);
                $('#emrDoctorId').val(doctorId);
                $('#emrTemplateId').val(data.template.templateId);
                $('#emrOPDServiceId').val(activeOPDServiceId);

                $('#emrOPDBillNo').val(data.booking.opdBillNo || 'N/A');
                $('#emrPatientCode').val(data.booking.patientCode || 'N/A');
                $('#emrPatientName').val(data.booking.patientName || 'N/A');
                $('#emrGender').val(data.booking.gender || 'N/A');
                $('#emrAge').val(data.booking.age ? `${data.booking.age} Yrs` : 'N/A');
                $('#emrMobileNumber').val(data.booking.mobileNumber || 'N/A');
                $('#emrVisitDate').val(data.booking.visitDate || 'N/A');
                
                $('#emrTemplateNameSub').text(data.template.templateName);

                // Set saved visit header info if available
                if (data.savedConsultation) {
                    $('#emrVisitType').val(data.savedConsultation.visitType);
                    $('#emrConsultationType').val(data.savedConsultation.consultationType);
                } else {
                    $('#emrVisitType').val('New');
                    $('#emrConsultationType').val(data.booking.bookedConsultingType || 'Walking');
                }

                // Populate vitals reference bar
                const bp = $('#vitalBP').text() || '--/--';
                const pulse = $('#vitalPulse').text() || '--';
                const temp = $('#vitalTemp').text() || '--';
                const spo2 = $('#vitalSpO2').text() || '--';
                const weight = $('#vitalWeight').text() || '--';
                const glucose = $('#vitalGlucose').text() || '--';

                $('#emrVitalsReference').html(`
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle"><i class="bi bi-heart-fill me-1"></i>BP: ${bp} mmHg</span>
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle"><i class="bi bi-activity me-1"></i>Pulse: ${pulse} bpm</span>
                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle"><i class="bi bi-thermometer-half me-1"></i>Temp: ${temp} °F</span>
                    <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle"><i class="bi bi-droplet-fill me-1"></i>SpO2: ${spo2}%</span>
                    <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle"><i class="bi bi-speedometer2 me-1"></i>Weight: ${weight} kg</span>
                    <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle"><i class="bi bi-droplet me-1"></i>Glucose: ${glucose}</span>
                `);

                // Parse any saved dynamic values
                let savedValues = {};
                if (data.savedConsultation && data.savedConsultation.emrDataJson) {
                    try {
                        savedValues = JSON.parse(data.savedConsultation.emrDataJson);
                    } catch (e) {
                        console.error('Failed to parse saved EMR json:', e);
                    }
                }

                // Build dynamic template UI
                const canvas = $('#emrDynamicFieldsCanvas');
                canvas.empty();

                data.template.sections.forEach(sec => {
                    const secCard = $(`
                        <div class="card border-0 shadow-sm mb-4 bg-white rounded-12 overflow-hidden">
                            <div class="card-header bg-light py-2 px-3 border-0">
                                <h6 class="fw-bold mb-0 text-dark small text-uppercase" style="letter-spacing: 0.5px;"><i class="bi bi-grid-fill text-primary me-2"></i>${sec.sectionName}</h6>
                            </div>
                            <div class="card-body">
                                <div class="row g-3" id="sec-fields-${sec.sectionId}"></div>
                            </div>
                        </div>
                    `);

                    const fieldsRow = secCard.find(`#sec-fields-${sec.sectionId}`);
                    sec.fields.forEach(f => {
                        const col = $('<div class="col-md-6 mb-1"></div>');
                        const isRequiredAsterisk = f.isRequired ? '<span class="text-danger">*</span>' : '';
                        const requiredAttr = f.isRequired ? 'required' : '';
                        const label = $(`<label class="form-label fw-semibold small text-muted mb-1">${f.fieldName} ${isRequiredAsterisk}</label>`);
                        col.append(label);

                        const savedVal = savedValues[f.fieldId] !== undefined ? savedValues[f.fieldId] : '';

                        // Render field based on type
                        if (f.fieldType === 'Text') {
                            col.append(`<input type="text" class="form-control form-control-sm emr-field-input" data-field-id="${f.fieldId}" data-field-name="${f.fieldName}" value="${savedVal}" ${requiredAttr} />`);
                        } 
                        else if (f.fieldType === 'TextArea') {
                            col.append(`<textarea class="form-control form-control-sm emr-field-input" data-field-id="${f.fieldId}" data-field-name="${f.fieldName}" rows="3" ${requiredAttr}>${savedVal}</textarea>`);
                        }
                        else if (f.fieldType === 'Number') {
                            col.append(`<input type="number" class="form-control form-control-sm emr-field-input" data-field-id="${f.fieldId}" data-field-name="${f.fieldName}" value="${savedVal}" ${requiredAttr} />`);
                        }
                        else if (f.fieldType === 'Date') {
                            const formattedDate = savedVal ? savedVal.split('T')[0] : '';
                            col.append(`<input type="date" class="form-control form-control-sm emr-field-input" data-field-id="${f.fieldId}" data-field-name="${f.fieldName}" value="${formattedDate}" ${requiredAttr} />`);
                        }
                        else if (f.fieldType === 'Checkbox') {
                            const isChecked = savedVal === true || savedVal === 'true' ? 'checked' : '';
                            col.append(`
                                <div class="form-check form-switch mt-1">
                                    <input class="form-check-input emr-field-input" type="checkbox" role="switch" data-field-id="${f.fieldId}" data-field-name="${f.fieldName}" ${isChecked} />
                                    <label class="form-check-label text-secondary small">Active / Enabled</label>
                                </div>
                            `);
                        }
                        else if (f.fieldType === 'Select') {
                            const sel = $(`<select class="form-select form-select-sm emr-field-input" data-field-id="${f.fieldId}" data-field-name="${f.fieldName}" ${requiredAttr}></select>`);
                            sel.append('<option value="">-- Choose Option --</option>');
                            f.options.forEach(opt => {
                                const isSel = opt.trim() === savedVal ? 'selected' : '';
                                sel.append(`<option value="${opt.trim()}" ${isSel}>${opt.trim()}</option>`);
                            });
                            col.append(sel);
                        }
                        else if (f.fieldType === 'MultiSelect') {
                            const multisel = $(`<select class="form-select form-select-sm select2-emr emr-field-input" multiple="multiple" data-field-id="${f.fieldId}" data-field-name="${f.fieldName}" ${requiredAttr}></select>`);
                            const savedList = typeof savedVal === 'string' ? savedVal.split(',') : Array.isArray(savedVal) ? savedVal : [];
                            f.options.forEach(opt => {
                                const isSel = savedList.includes(opt.trim()) ? 'selected' : '';
                                multisel.append(`<option value="${opt.trim()}" ${isSel}>${opt.trim()}</option>`);
                            });
                            col.append(multisel);
                        }
                        else if (f.fieldType === 'Investigation' || f.fieldType === 'Medication') {
                            // Clinical List AutoSuggest Component
                            const color = f.fieldType === 'Investigation' ? 'success' : 'warning';
                            const icon = f.fieldType === 'Investigation' ? 'bi-eyedropper' : 'bi-capsule';
                            const placeholder = f.fieldType === 'Investigation' ? 'Search investigations...' : 'Search medications...';

                            const listComponent = $(`
                                <div class="p-2 border rounded bg-white shadow-xs field-row" data-field-type="${f.fieldType}" data-field-id="${f.fieldId}">
                                    <div class="selected-items-container d-flex flex-wrap gap-1 mb-2 p-1 border rounded bg-light" style="min-height: 32px;"></div>
                                    <div class="position-relative">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text bg-light"><i class="bi ${icon} text-${color}"></i></span>
                                            <input type="text" class="form-control autosuggest-input" placeholder="${placeholder}" autocomplete="off" />
                                        </div>
                                        <div class="autosuggest-dropdown dropdown-menu w-100 p-0 border shadow-sm" style="display:none; max-height:180px; overflow-y:auto; position:absolute; z-index:1050;"></div>
                                    </div>
                                </div>
                            `);

                            // Hydrate previously saved medications/investigations
                            if (savedVal) {
                                const items = savedVal.split(',');
                                const container = listComponent.find('.selected-items-container');
                                items.forEach(itm => {
                                    const parts = itm.split('|');
                                    const itemId = parts[0];
                                    const itemText = parts.length > 1 ? parts[1] : parts[0];
                                    
                                    if (itemId && itemText) {
                                        const tag = $(`
                                            <span class="badge bg-light text-dark border me-1 mb-1 d-inline-flex align-items-center gap-1 selected-item-tag" data-item-id="${itemId}" data-item-text="${itemText}">
                                                ${itemText}
                                                <button type="button" class="btn-close btn-close-dark" style="font-size:0.5rem;"></button>
                                            </span>
                                        `);
                                        tag.find('.btn-close').on('click', function () { tag.remove(); });
                                        container.append(tag);
                                    }
                                });
                            }

                            col.empty().append(label).append(listComponent);
                            setupAutoSuggest(listComponent, f.fieldType);
                        }

                        fieldsRow.append(col);
                    });

                    canvas.append(secCard);
                });

                // Initialize select2 if active
                if (typeof $.fn.select2 !== 'undefined') {
                    $('.select2-emr').select2({
                        dropdownParent: $('#emrConsultationModal'),
                        theme: 'bootstrap-5',
                        width: '100%'
                    });
                }

                // Show modal
                const myModal = new bootstrap.Modal(document.getElementById('emrConsultationModal'));
                myModal.show();

            } catch (err) {
                console.error("EMR load failed:", err);
                Swal.fire('Error', 'Failed to retrieve EMR template.', 'error');
            }
        }

        // AutoSuggest dynamic engine inside Dashboard EMR modal
        function setupAutoSuggest(fieldComponent, fieldType) {
            const endpoint = fieldType === 'Investigation' ? '/EmrInvestigations/Search' : '/EmrMedications/Search';
            const suggestBox = fieldComponent.find('.autosuggest-input');
            const dropdown = fieldComponent.find('.autosuggest-dropdown');
            const container = fieldComponent.find('.selected-items-container');

            suggestBox.on('input', async function () {
                const q = $(this).val().trim();
                if (q.length < 1) { dropdown.hide(); return; }

                try {
                    const res = await fetch(`${endpoint}?q=${encodeURIComponent(q)}`);
                    const items = await res.json();
                    dropdown.empty();

                    if (items.length === 0) {
                        dropdown.html('<div class="dropdown-item-text text-muted small py-2">No results found</div>').show();
                        return;
                    }

                    items.forEach(item => {
                        const li = $(`<button type="button" class="dropdown-item py-2 d-flex align-items-center gap-1">
                            <span class="fw-semibold">${item.text}</span>
                        </button>`);

                        li.on('click', function () {
                            // Add badge tag
                            if (container.find(`[data-item-id="${item.id}"]`).length === 0) {
                                const tag = $(`
                                    <span class="badge bg-light text-dark border me-1 mb-1 d-inline-flex align-items-center gap-1 selected-item-tag" data-item-id="${item.id}" data-item-text="${item.text}">
                                        ${item.text}
                                        <button type="button" class="btn-close btn-close-dark" style="font-size:0.5rem;"></button>
                                    </span>
                                `);
                                tag.find('.btn-close').on('click', function () { tag.remove(); });
                                container.append(tag);
                            }
                            suggestBox.val('');
                            dropdown.hide();
                        });
                        dropdown.append(li);
                    });

                    dropdown.show();
                } catch (e) {
                    console.error('AutoSuggest error:', e);
                }
            });

            // Close dropdown on outside click
            $(document).on('click.autosuggest-dashboard', function (e) {
                if (!fieldComponent[0].contains(e.target)) dropdown.hide();
            });
        }

        async function saveEMRRecord() {
            const opdServiceId = $('#emrOPDServiceId').val();
            if (!opdServiceId) return;

            // Collect dynamic EMR fields value
            const emrData = {};
            
            // Loop through dynamic field inputs
            $('.emr-field-input').each(function() {
                const id = $(this).attr('data-field-id');
                if (!id) return;
                
                if ($(this).attr('type') === 'checkbox') {
                    emrData[id] = $(this).is(':checked');
                } else if ($(this).prop('multiple')) {
                    const vals = $(this).val();
                    emrData[id] = vals ? vals.join(',') : '';
                } else {
                    emrData[id] = $(this).val();
                }
            });

            // Loop through medication / investigation list components
            $('#emrDynamicFieldsCanvas .field-row').each(function() {
                const id = $(this).attr('data-field-id');
                if (!id) return;
                
                const selected = [];
                $(this).find('.selected-item-tag').each(function() {
                    const itemId = $(this).attr('data-item-id');
                    const itemText = $(this).attr('data-item-text');
                    selected.push(itemId + '|' + itemText);
                });
                emrData[id] = selected.join(',');
            });

            const req = {
                OPDServiceId: parseInt(opdServiceId),
                PatientId: parseInt($('#emrPatientId').val()),
                DoctorId: parseInt($('#emrDoctorId').val()),
                TemplateId: parseInt($('#emrTemplateId').val()),
                OPDBillNo: $('#emrOPDBillNo').val(),
                PatientCode: $('#emrPatientCode').val(),
                PatientName: $('#emrPatientName').val(),
                Gender: $('#emrGender').val(),
                Age: $('#emrAge').val()?.replace(' Yrs', ''),
                MobileNumber: $('#emrMobileNumber').val(),
                VisitType: $('#emrVisitType').val(),
                ConsultationType: $('#emrConsultationType').val(),
                EmrDataJson: JSON.stringify(emrData)
            };

            Swal.fire({
                title: 'Saving EMR Record...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            try {
                const res = await fetch('/OPD/SavePatientConsultation', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(req)
                });
                const result = await res.json();
                Swal.close();

                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Saved Successfully',
                        text: result.message,
                        timer: 2000,
                        showConfirmButton: false
                    });
                    
                    // Close the modal
                    const modalEl = document.getElementById('emrConsultationModal');
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();
                    
                    // Refresh queue to show updated status
                    fetchQueue();
                    clearActivePatient();
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (err) {
                console.error(err);
                Swal.close();
                Swal.fire('Error', 'An unexpected error occurred while saving EMR.', 'error');
            }
        }

