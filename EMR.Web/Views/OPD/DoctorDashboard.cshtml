        function callPatient(opdServiceId, name, tokenNo) {
            calledPatientsSet.add(opdServiceId);
            callingPatientId = opdServiceId;
            
            // Re-render table to display sound wave animation
            renderQueueTable();
            
            // Speech synthesis call out for premium standard doctor dashboard experience!
            if ('speechSynthesis' in window) {
                // Cancel any pending speech
                window.speechSynthesis.cancel();
                
                // Set dynamic voice and room name based on selected doctor
                const doctorSelect = document.getElementById('ddlDoctorDashboard');
                const selectedOpt = doctorSelect ? doctorSelect.selectedOptions[0] : null;
                
                let text = `Token number ${tokenNo}, patient ${name}, please come to `;
                if (selectedOpt) {
                    const docName = selectedOpt.text.split(' (')[0];
                    const roomInfo = doctorRoomMap[docName];
                    if (roomInfo) {
                        text += `Consulting room ${roomInfo}`;
                    } else {
                        text += "consulting room";
                    }
                } else {
                    text += "consulting room";
                }
                
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.rate = 0.9;

                const docGender = selectedOpt ? (selectedOpt.getAttribute('data-gender') || 'Male') : 'Male';
                const voice = getVoiceForGender(docGender);
                if (voice) {
                    utterance.voice = voice;
                }
                
                utterance.onend = function() {
                    callingPatientId = null;
                    renderQueueTable();
                };
                utterance.onerror = function() {
                    callingPatientId = null;
                    renderQueueTable();
                };
                
                window.speechSynthesis.speak(utterance);
            } else {
                setTimeout(() => {
                    callingPatientId = null;
                    renderQueueTable();
                }, 2000);
            }

            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: `Called Token ${tokenNo}: ${name}`,
                showConfirmButton: false,
                timer: 2000
            });
        }

        function completeConsultingFromNotes() {
            if (!activeOPDServiceId) return;
            const patient = allQueuePatients.find(p => p.opdServiceId === activeOPDServiceId);
            if (patient) {
                completeConsulting(activeOPDServiceId, patient.patientName, patient.isEmrDone);
            } else {
                completeConsulting(activeOPDServiceId);
            }
        }

        async function completeConsulting(id, patientName = null, isEmrDone = true) {
            let title = 'Complete Consultation?';
            let text = "Are you sure you want to mark this patient's consultation as completed?";
            let icon = 'question';

            if (isEmrDone === false) {
                title = 'Warning: EMR Not Done';
                text = `EMR is not done for patient ${patientName}. Still you want to complete?`;
                icon = 'warning';
            }

            Swal.fire({
                title: title,
                text: text,
                icon: icon,
                showCancelButton: true,
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, complete!'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const res = await fetch('/OPD/UpdateTokenStatus', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id: id, status: 'Completed' })
                        });
                        
                        const json = await res.json();
                        if (json.isSuccess) {
                            Swal.fire({
                                toast: true,
                                position: 'top-end',
                                icon: 'success',
                                title: 'Consultation marked completed',
                                showConfirmButton: false,
                                timer: 1500
                            });
                            
                            // Remove from called patients tracking and local storage drafts on complete
                            calledPatientsSet.delete(id);
                            localStorage.removeItem('emr_notes_opd_' + id);
                            
                            if (id === activeOPDServiceId) {
                                clearActivePatient();
                            }

                            fetchQueue();
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    } catch (err) {
                        console.error(err);
                        Swal.fire('Error', 'An unexpected error occurred.', 'error');
                    }
                }
            });
        }

        async function skipConsulting(id) {
            Swal.fire({
                title: 'Skip/Pass Patient?',
                text: "Are you sure you want to skip this patient? They will remain in the active queue but move to the bottom.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, skip!'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const res = await fetch('/OPD/UpdateTokenStatus', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id: id, status: 'Skipped' })
                        });
                        
                        const json = await res.json();
                        if (json.isSuccess) {
                            Swal.fire({
                                toast: true,
                                position: 'top-end',
                                icon: 'success',
                                title: 'Patient marked as skipped',
                                showConfirmButton: false,
                                timer: 1500
                            });
                            
                            if (id === activeOPDServiceId) {
                                clearActivePatient();
                            }

                            fetchQueue();
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    } catch (err) {
                        console.error(err);
                        Swal.fire('Error', 'An unexpected error occurred.', 'error');
                    }
                }
            });
        }

