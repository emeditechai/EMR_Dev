@{
    ViewData["Title"] = "Doctor Dashboard";
    var doctors = ViewBag.Doctors as IEnumerable<(int DoctorId, string FullName, int? PrimarySpecialityId, string Gender)> ?? new List<(int, string, int?, string)>();
    var defaultDoctorId = ViewBag.DefaultDoctorId is int id ? id : 0;
    var doctorRoomMap = ViewBag.DoctorRoomMap as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<!-- Bootstrap Select CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-select@1.14.0-beta3/dist/css/bootstrap-select.min.css">

<div class="container-fluid" id="config-page-container">
    <!-- Header Bar -->
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2 bg-white p-2.5 rounded-12 shadow-xs border">
        <div>
            @if (ViewBag.IsDoctor == true)
            {
                <h5 class="mb-0 text-primary fw-bold"><i class="bi bi-hand-wave-fill me-2 text-warning"></i>Welcome, @ViewBag.DoctorName</h5>
                <p class="text-muted small mb-0" style="font-size: 0.74rem;">Live Queue Manager & Console</p>
            }
            else
            {
                <h5 class="mb-0 text-primary fw-bold"><i class="bi bi-person-badge-fill me-2"></i>Doctor Dashboard</h5>
                <p class="text-muted small mb-0" style="font-size: 0.74rem;">Live Queue Manager & Console</p>
            }
        </div>
        <div class="d-flex align-items-center flex-wrap gap-2">
            <!-- Room Badge -->
            <div id="roomBadgeContainer" class="d-flex align-items-center"></div>
            
            <!-- Doctor Select Dropdown -->
            <div style="width: 240px;" class="@(ViewBag.IsDoctor == true ? "d-none" : "")">
                <select id="ddlDoctorDashboard" class="selectpicker-custom form-control form-control-sm" data-live-search="true" title="Select Doctor Dashboard" onchange="onDoctorChanged()">
                    @foreach (var doc in doctors)
                    {
                        var isDefault = doc.DoctorId == defaultDoctorId ? "selected" : "";
                        var roomInfo = doctorRoomMap.TryGetValue(doc.FullName, out var rm) ? $" ({rm})" : "";
                        <!option value="@doc.DoctorId" data-gender="@doc.Gender" @isDefault>@doc.FullName @roomInfo</!option>
                    }
                </select>
            </div>

            <!-- Auto Refresh Switch -->
            <div class="form-check form-switch mb-0 ms-1 me-2">
                <input class="form-check-input" type="checkbox" role="switch" id="chkAutoRefresh" checked onchange="toggleAutoRefresh()">
                <label class="form-check-label small text-muted ms-1" for="chkAutoRefresh" style="font-size: 0.78rem; user-select: none;">Auto <span id="lblCountdown" class="fw-bold text-primary"></span></label>
            </div>

            <!-- Controls -->
            <button class="btn btn-outline-secondary btn-sm p-1.5 px-2" id="darkModeToggle" onclick="toggleDarkMode()" title="Toggle Theme" style="border-radius: 8px;">
                <i class="bi bi-moon-stars-fill text-primary" id="darkModeIcon"></i>
            </button>
            <button class="btn btn-primary btn-sm p-1.5 px-2" onclick="fetchQueue()" title="Refresh Queue" style="border-radius: 8px;">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    <!-- Top Stats Row -->
    <div class="row g-2 mb-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-xs stat-card stat-card-waiting">
                <div class="card-body d-flex align-items-center p-2.5">
                    <div class="rounded-3 p-2 me-2.5 text-primary icon-box-purple" style="font-size: 1.3rem; line-height: 1; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div>
                        <span class="text-muted small fw-semibold d-block" style="font-size: 0.74rem;">Waiting In Queue</span>
                        <h4 class="mb-0 fw-bold text-dark" id="statWaiting" style="line-height: 1.2;">0</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-xs stat-card stat-card-completed">
                <div class="card-body d-flex align-items-center p-2.5">
                    <div class="rounded-3 p-2 me-2.5 text-success icon-box-green" style="font-size: 1.3rem; line-height: 1; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <div>
                        <span class="text-muted small fw-semibold d-block" style="font-size: 0.74rem;">Completed Today</span>
                        <h4 class="mb-0 fw-bold text-dark" id="statCompleted" style="line-height: 1.2;">0</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-xs stat-card stat-card-active">
                <div class="card-body d-flex align-items-center p-2.5">
                    <div class="rounded-3 p-2 me-2.5 text-warning icon-box-orange" style="font-size: 1.3rem; line-height: 1; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-megaphone-fill"></i>
                    </div>
                    <div>
                        <span class="text-muted small fw-semibold d-block" style="font-size: 0.74rem;">Active Consultation</span>
                        <h5 class="mb-0 fw-bold text-dark text-truncate" id="statActivePatient" style="max-width: 220px; line-height: 1.2;">None</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Workspace -->
    <div class="row g-2">
        <!-- Left: Patients Queue (Col-8) -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-xs rounded-12 overflow-hidden">
                <!-- Segmented Tabs and Search Filter Bar -->
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 border-bottom py-2 px-3 bg-white" id="queueTableHeader">
                    <div class="segmented-tabs" id="queueTabs">
                        <button class="segmented-tab active" id="tabActive" onclick="changeQueueTab('active')" style="padding: 6px 12px; font-size: 0.8rem; border-radius: 6px;">
                            <i class="bi bi-people"></i> Active Queue <span class="badge bg-secondary ms-1" id="badgeActiveCount">0</span>
                        </button>
                        <button class="segmented-tab" id="tabCompleted" onclick="changeQueueTab('completed')" style="padding: 6px 12px; font-size: 0.8rem; border-radius: 6px;">
                            <i class="bi bi-check-circle"></i> Completed Today <span class="badge bg-secondary ms-1" id="badgeCompletedCount">0</span>
                        </button>
                    </div>
                    
                    <!-- Search Filter -->
                    <div class="position-relative" style="width: 200px;">
                        <i class="bi bi-search position-absolute text-muted" style="left: 10px; top: 50%; transform: translateY(-50%); font-size: 0.78rem;"></i>
                        <input type="text" id="queueSearch" placeholder="Search name/ID/token..." class="form-control form-control-sm ps-4 rounded-pill" style="font-size: 0.78rem;" oninput="filterQueueTable()">
                    </div>
                </div>
                
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="queueTable">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3" style="width: 70px;">Token</th>
                                    <th>Patient Info</th>
                                    <th>Visit Time</th>
                                    <th>Status &amp; Dues</th>
                                    <th class="text-end pe-3" style="width: 290px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">
                                        <i class="spinner-border text-primary spinner-border-sm me-2"></i> Loading queue...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Active Patient Profile & Vitals (Col-4) -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-xs rounded-12 bg-white h-100" id="patientDetailCard">
                <div class="card-body p-3 text-center py-4 text-muted d-flex flex-column align-items-center justify-content-center h-100">
                    <div class="mb-2" style="font-size: 2.5rem; color: #cbd5e1;">
                        <i class="bi bi-person-circle"></i>
                    </div>
                    <h6 class="fw-bold text-dark mb-1" style="font-size: 0.9rem;">No Patient Active</h6>
                    <p class="small mb-0 text-secondary" style="font-size: 0.78rem;">Select a patient from the queue and click <strong>Start EMR</strong> to load details & vital signs.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Dynamic EMR Consultation Modal -->
<div class="modal fade" id="emrConsultationModal" tabindex="-1" aria-labelledby="emrConsultationModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header bg-primary text-white py-3 px-4 border-0">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-journal-medical fs-4"></i>
                    <div>
                        <h5 class="modal-title fw-bold mb-0" id="emrConsultationModalLabel">EMR Clinical Consultation</h5>
                        <small class="text-white-50 fs-8" id="emrTemplateNameSub">Speciality EMR Template</small>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-light-subtle px-4 py-3">
                <!-- Vitals Strip Reference -->
                <div class="card border-0 shadow-xs mb-3 bg-white p-2.5 rounded-12">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 fs-7.5">
                        <span class="fw-bold text-secondary"><i class="bi bi-activity text-danger me-1"></i>Active Patient Vitals Reference:</span>
                        <div class="d-flex flex-wrap gap-3" id="emrVitalsReference">
                            <!-- Populated dynamically -->
                        </div>
                    </div>
                </div>

                <!-- Common EMR Header (Fixed Fields) -->
                <div class="card border-0 shadow-sm mb-4 bg-white rounded-12 overflow-hidden">
                    <div class="card-header bg-light py-2 px-3 border-0">
                        <span class="fw-bold text-secondary small text-uppercase"><i class="bi bi-person-lines-fill me-1"></i>Common Patient Header</span>
                    </div>
                    <div class="card-body py-3">
                        <div class="row g-3 small">
                            <input type="hidden" id="emrPatientId" />
                            <input type="hidden" id="emrDoctorId" />
                            <input type="hidden" id="emrTemplateId" />
                            <input type="hidden" id="emrOPDServiceId" />

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-semibold text-muted mb-1">OPD BILL NO</label>
                                <input type="text" id="emrOPDBillNo" class="form-control form-control-sm bg-light" readonly />
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-semibold text-muted mb-1">PATIENT ID</label>
                                <input type="text" id="emrPatientCode" class="form-control form-control-sm bg-light" readonly />
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-semibold text-muted mb-1">PATIENT NAME</label>
                                <input type="text" id="emrPatientName" class="form-control form-control-sm bg-light fw-bold" readonly />
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-semibold text-muted mb-1">GENDER</label>
                                <input type="text" id="emrGender" class="form-control form-control-sm bg-light" readonly />
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-semibold text-muted mb-1">DOB / AGE</label>
                                <input type="text" id="emrAge" class="form-control form-control-sm bg-light" readonly />
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-semibold text-muted mb-1">MOBILE NUMBER</label>
                                <input type="text" id="emrMobileNumber" class="form-control form-control-sm bg-light" readonly />
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-semibold text-muted mb-1">VISIT DATE & TIME</label>
                                <input type="text" id="emrVisitDate" class="form-control form-control-sm bg-light" readonly />
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-semibold text-muted mb-1">VISIT TYPE <span class="text-danger">*</span></label>
                                <select id="emrVisitType" class="form-select form-select-sm">
                                    <option value="New">New Consultation</option>
                                    <option value="Follow-up">Follow-up Visit</option>
                                </select>
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label fw-semibold text-muted mb-1">CONSULTATION TYPE <span class="text-danger">*</span></label>
                                <select id="emrConsultationType" class="form-select form-select-sm">
                                    <option value="Walking">Walking / OPD</option>
                                    <option value="Video">Video Consultation</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Dynamic EMR Fields Canvas -->
                <div id="emrDynamicFieldsCanvas">
                    <!-- Dynamic sections & fields will load here via JavaScript -->
                </div>
            </div>
            <div class="modal-footer bg-light border-0 py-3 px-4 d-flex justify-content-between">
                <div>
                    <button type="button" class="btn btn-outline-info" id="btnPrintEmrRecord">
                        <i class="bi bi-printer me-1"></i>Print Consultation
                    </button>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary px-4 fw-bold" id="btnSaveEmrRecord">
                        <i class="bi bi-check-circle me-1"></i>Save Consultation
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Bootstrap Select JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-select@1.14.0-beta3/dist/js/bootstrap-select.min.js"></script>

    <!-- Google Fonts Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        /* Compact layout overrides */
        #config-page-container {
            padding: 0.85rem !important;
        }
        #queueTable th, #queueTable td {
            padding: 8px 12px !important;
            font-size: 0.82rem !important;
        }
        #queueTable td .badge {
            font-size: 0.72rem !important;
            padding: 3px 6px !important;
        }
        .font-xs {
            font-size: 0.72rem !important;
        }

        .rounded-12 {
            border-radius: 12px !important;
        }
        .shadow-xs {
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02) !important;
        }
        .bg-light-primary {
            background-color: rgba(99, 102, 241, 0.08) !important;
        }
        .bg-light-success {
            background-color: rgba(16, 185, 129, 0.08) !important;
        }
        .bg-light-warning {
            background-color: rgba(245, 158, 11, 0.08) !important;
        }
        .btn-xs {
            padding: 0.15rem 0.4rem;
            font-size: 0.72rem;
            border-radius: 4px;
        }
        
        /* Auto countdown styles */
        #lblCountdown {
            font-variant-numeric: tabular-nums;
        }
        
        /* Color system & variables */
        body {
            --bg-main: #f8fafc;
            --bg-card: #ffffff;
            --bg-header: #ffffff;
            --border-color: #e2e8f0;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #64748b;
            --table-hover-bg: #f8fafc;
            --btn-light-bg: #f8fafc;
            --btn-light-border: #e2e8f0;
            --modal-bg: #ffffff;
            --modal-header-bg: #f8fafc;
            --input-bg: #ffffff;
            --input-border: #cbd5e1;
            --input-text: #0f172a;
            --vital-box-bg: #f8fafc;
            --card-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.03), 0 2px 4px -2px rgb(0 0 0 / 0.03);
            --card-shadow-hover: 0 10px 15px -3px rgb(0 0 0 / 0.05), 0 4px 6px -4px rgb(0 0 0 / 0.05);
            --accent-primary: #6366f1;
            --accent-primary-hover: #4f46e5;
            --accent-primary-light: rgba(99, 102, 241, 0.06);
        }

        body.dark-mode {
            --bg-main: #0b0f19;
            --bg-card: #151b2c;
            --bg-header: #151b2c;
            --border-color: #242f47;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --table-hover-bg: #1e293b;
            --btn-light-bg: #1e2538;
            --btn-light-border: #242f47;
            --modal-bg: #151b2c;
            --modal-header-bg: #0b0f19;
            --input-bg: #0b0f19;
            --input-border: #242f47;
            --input-text: #f8fafc;
            --vital-box-bg: #151b2c;
            --card-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.2), 0 2px 4px -2px rgb(0 0 0 / 0.2);
            --card-shadow-hover: 0 10px 15px -3px rgb(0 0 0 / 0.3), 0 4px 6px -4px rgb(0 0 0 / 0.3);
            --accent-primary: #818cf8;
            --accent-primary-hover: #6366f1;
            --accent-primary-light: rgba(129, 140, 248, 0.12);
        }
        
        /* Interactive Stat Cards */
        .stat-card {
            border: 1px solid var(--border-color) !important;
            background: var(--bg-card) !important;
            box-shadow: var(--card-shadow) !important;
            border-radius: 16px !important;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            position: relative;
        }
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
        }
        .stat-card-waiting::before { background: var(--accent-primary); }
        .stat-card-completed::before { background: #10b981; }
        .stat-card-active::before { background: #f59e0b; }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--card-shadow-hover) !important;
        }
        
        /* Icon color classes */
        .icon-box-purple {
            background-color: rgba(99, 102, 241, 0.08) !important;
            color: var(--accent-primary) !important;
        }
        .icon-box-green {
            background-color: rgba(16, 185, 129, 0.08) !important;
            color: #10b981 !important;
        }
        .icon-box-orange {
            background-color: rgba(245, 158, 11, 0.08) !important;
            color: #f59e0b !important;
        }
        
        /* Segmented Tabs */
        .segmented-tabs {
            background-color: var(--btn-light-bg);
            border: 1px solid var(--border-color);
            padding: 4px;
            border-radius: 12px;
            display: inline-flex;
            gap: 4px;
        }
        .segmented-tab {
            border: none;
            background: transparent;
            color: var(--text-secondary);
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .segmented-tab.active {
            background-color: var(--accent-primary);
            color: #ffffff;
            box-shadow: 0 4px 10px rgba(99, 102, 241, 0.2);
        }
        .segmented-tab .badge {
            font-size: 0.72rem;
            padding: 2px 6px;
            border-radius: 6px;
        }
        .segmented-tab.active .badge {
            background-color: rgba(255, 255, 255, 0.2) !important;
            color: #ffffff !important;
        }
        
        /* Calling sound wave animation */
        .sound-wave {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            height: 12px;
            margin-left: 8px;
        }
        .sound-wave span {
            display: block;
            width: 2.5px;
            height: 4px;
            background-color: #3b82f6;
            border-radius: 1px;
            animation: soundWaveAnim 1s ease-in-out infinite;
        }
        .sound-wave span:nth-child(2) { animation-delay: 0.15s; }
        .sound-wave span:nth-child(3) { animation-delay: 0.3s; }
        .sound-wave span:nth-child(4) { animation-delay: 0.45s; }

        @@keyframes soundWaveAnim {
            0%, 100% { height: 3px; }
            50% { height: 12px; }
        }
        
        /* Active row highlights */
        .active-row {
            background-color: var(--accent-primary-light) !important;
            border-left: 4px solid var(--accent-primary) !important;
        }
        #queueTable tbody tr {
            border-left: 4px solid transparent;
            transition: all 0.15s ease;
        }
        #queueTable tbody tr:hover {
            background-color: var(--table-hover-bg) !important;
        }

        /* Vitals layout box styles */
        .vital-box {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-left: 4px solid var(--border-color);
            transition: all 0.2s ease;
        }
        .vital-box.normal {
            border-left-color: #10b981;
        }
        .vital-box.warning {
            border-left-color: #f59e0b;
        }
        .vital-box.critical {
            border-left-color: #ef4444;
        }
        .vital-box:hover {
            transform: scale(1.02);
            box-shadow: var(--card-shadow) !important;
        }

        #config-page-container {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif !important;
            background-color: var(--bg-main);
            color: var(--text-primary);
            transition: all 0.25s ease-in-out;
            padding: 1.5rem;
            border-radius: 12px;
        }

        /* Base style overrides utilizing custom properties */
        #config-page-container .card {
            background-color: var(--bg-card) !important;
            border-color: var(--border-color) !important;
            color: var(--text-primary) !important;
            box-shadow: var(--card-shadow) !important;
        }
        #config-page-container .card-header {
            background-color: var(--bg-header) !important;
            border-bottom: 1px solid var(--border-color) !important;
            color: var(--text-primary) !important;
        }
        #config-page-container #queueTableHeader {
            background-color: var(--bg-header) !important;
        }
        #config-page-container .table {
            color: var(--text-primary) !important;
        }
        #config-page-container .table th {
            background-color: var(--bg-header) !important;
            border-color: var(--border-color) !important;
            color: var(--text-secondary) !important;
        }
        #config-page-container .table td {
            border-color: var(--border-color) !important;
        }
        #config-page-container .table-hover tbody tr:hover {
            background-color: var(--table-hover-bg) !important;
        }
        #config-page-container .text-muted {
            color: var(--text-muted) !important;
        }
        #config-page-container .text-dark {
            color: var(--text-primary) !important;
        }
        #config-page-container .bg-light {
            background-color: var(--bg-main) !important;
        }
        #config-page-container .border-top {
            border-top: 1px solid var(--border-color) !important;
        }
        #config-page-container .btn-light {
            background-color: var(--btn-light-bg) !important;
            border-color: var(--btn-light-border) !important;
            color: var(--text-primary) !important;
        }
        #config-page-container .btn-light:hover {
            background-color: var(--border-color) !important;
        }
        #config-page-container .form-control {
            background-color: var(--input-bg);
            border-color: var(--input-border);
            color: var(--input-text);
        }
        #config-page-container .form-control:focus {
            background-color: var(--input-bg);
            color: var(--input-text);
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 0.25rem rgba(99, 102, 241, 0.25);
        }
        
        /* Dark Mode Specific Vitals overrides */
        body.dark-mode .vital-box {
            background-color: var(--bg-card) !important;
        }

        body.dark-mode .modal-content {
            background-color: var(--modal-bg) !important;
            color: var(--text-primary) !important;
            border: 1px solid var(--border-color) !important;
        }
        body.dark-mode .modal-header {
            background-color: var(--modal-header-bg) !important;
            border-bottom: 1px solid var(--border-color) !important;
        }
        body.dark-mode .modal-header .btn-close {
            filter: invert(1) grayscale(1) brightness(2);
        }
        body.dark-mode .dropdown-menu {
            background-color: var(--bg-card) !important;
            border-color: var(--border-color) !important;
        }
        body.dark-mode .dropdown-menu .dropdown-item {
            color: var(--text-primary) !important;
        }
        body.dark-mode .dropdown-menu .dropdown-item:hover {
            background-color: var(--table-hover-bg) !important;
        }
        body.dark-mode .dropdown-menu .dropdown-item.active,
        body.dark-mode .dropdown-menu .dropdown-item:active {
            background-color: var(--accent-primary) !important;
            color: #fff !important;
        }
        body.dark-mode .bs-searchbox input {
            background-color: var(--input-bg) !important;
            border-color: var(--input-border) !important;
            color: var(--input-text) !important;
        }
    </style>

    <script>
        let currentSchedulesList = [];
        let activePatientId = null;
        let activeOPDServiceId = null;
        let autoRefreshInterval = null;
        let refreshCountdown = 30;
        
        // Global variables for queue and tabs
        let allQueuePatients = [];
        let activeQueueTab = 'active'; // 'active' or 'completed'
        
        // Use a Set to track which patients have been called in this session
        const calledPatientsSet = new Set();
        let callingPatientId = null;

        const doctorRoomMap = @Html.Raw(Json.Serialize(doctorRoomMap));

        function toggleDarkMode() {
            const container = document.getElementById('config-page-container');
            if (!container) return;
            
            const isDark = container.classList.toggle('dark-mode');
            document.body.classList.toggle('dark-mode', isDark);
            
            // Save preference
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            
            // Update button UI
            const icon = document.getElementById('darkModeIcon');
            const text = document.getElementById('darkModeText');
            if (isDark) {
                if (icon) icon.className = 'bi bi-sun-fill text-warning';
                if (text) text.innerText = 'Light Mode';
            } else {
                if (icon) icon.className = 'bi bi-moon-stars-fill text-primary';
                if (text) text.innerText = 'Dark Mode';
            }
        }

        // Dark Mode self-executing preference load
        (function() {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark') {
                document.body.classList.add('dark-mode');
                document.addEventListener('DOMContentLoaded', () => {
                    const container = document.getElementById('config-page-container');
                    if (container) {
                        container.classList.add('dark-mode');
                        const icon = document.getElementById('darkModeIcon');
                        const text = document.getElementById('darkModeText');
                        if (icon) icon.className = 'bi bi-sun-fill text-warning';
                        if (text) text.innerText = 'Light Mode';
                    }
                });
            }
        })();

        // Auto Refresh Handlers
        function startAutoRefresh() {
            stopAutoRefresh();
            refreshCountdown = 30;
            updateCountdownLabel();
            
            autoRefreshInterval = setInterval(() => {
                refreshCountdown--;
                updateCountdownLabel();
                
                if (refreshCountdown <= 0) {
                    fetchQueue();
                    refreshCountdown = 30;
                }
            }, 1000);
        }

        // Search queue filter
        function filterQueueTable() {
            const q = document.getElementById('queueSearch').value.toLowerCase().trim();
            const rows = document.querySelectorAll('#queueTable tbody tr');
            rows.forEach(row => {
                // Ignore spinner loading rows
                if (row.cells.length === 1 && row.cells[0].colSpan === 5) return;
                
                const text = row.innerText.toLowerCase();
                if (text.includes(q)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        function stopAutoRefresh() {
            if (autoRefreshInterval) {
                clearInterval(autoRefreshInterval);
                autoRefreshInterval = null;
            }
            document.getElementById('lblCountdown').innerText = '';
        }

        function toggleAutoRefresh() {
            const chk = document.getElementById('chkAutoRefresh');
            if (chk.checked) {
                startAutoRefresh();
            } else {
                stopAutoRefresh();
            }
        }

        function updateCountdownLabel() {
            const lbl = document.getElementById('lblCountdown');
            if (lbl && autoRefreshInterval) {
                lbl.innerText = `(${refreshCountdown}s)`;
            }
        }

        function onDoctorChanged() {
            fetchQueue();
            updateRoomBadge();
        }

        function updateRoomBadge() {
            const select = document.getElementById('ddlDoctorDashboard');
            const container = document.getElementById('roomBadgeContainer');
            container.innerHTML = '';
            
            if (select && select.selectedOptions && select.selectedOptions[0]) {
                const docName = select.selectedOptions[0].text.split(' (')[0];
                const roomInfo = doctorRoomMap[docName];
                if (roomInfo) {
                    container.innerHTML = `
                        <span class="badge bg-purple border text-white px-3 py-2 rounded-pill fs-7 shadow-xs">
                            <i class="bi bi-geo-alt-fill me-1"></i>${roomInfo}
                        </span>`;
                }
            }
        }

        function changeQueueTab(tabName) {
            activeQueueTab = tabName;
            document.querySelectorAll('.segmented-tab').forEach(t => t.classList.remove('active'));
            if (tabName === 'active') {
                document.getElementById('tabActive').classList.add('active');
            } else {
                document.getElementById('tabCompleted').classList.add('active');
            }
            renderQueueTable();
        }

        async function fetchQueue() {
            const select = document.getElementById('ddlDoctorDashboard');
            if (!select || !select.value) {
                renderEmptyQueue("Please select a doctor to load the consulting queue.");
                return;
            }

            const doctorId = select.value;
            try {
                const res = await fetch(`/OPD/GetDoctorConsultingQueue?doctorId=${doctorId}`);
                const result = await res.json();
                
                if (result.isSuccess) {
                    document.getElementById('statWaiting').innerText = result.totalWaiting;
                    document.getElementById('statCompleted').innerText = result.totalCompleted;
                    
                    allQueuePatients = result.data || [];
                    renderQueueTable();

                    // Auto-select patient from URL if present
                    const urlParams = new URLSearchParams(window.location.search);
                    const autoPatientId = urlParams.get('patientId');
                    if (autoPatientId && !window._autoSelected) {
                        window._autoSelected = true;
                        const patient = allQueuePatients.find(p => p.patientId == autoPatientId);
                        if (patient) {
                            const pyStatus = (patient.paymentStatus || 'U').toUpperCase();
                            const hasDue = pyStatus === 'U' || pyStatus === 'R';
                            startConsulting(patient.opdServiceId, patient.patientId, patient.patientName, patient.patientCode, patient.gender, patient.age, patient.tokenNo, hasDue);
                        }
                    }
                } else {
                    console.error("Error loading queue details.");
                }
            } catch (err) {
                console.error("Connection failed:", err);
            }
        }

        function renderEmptyQueue(message) {
            const tbody = document.querySelector('#queueTable tbody');
            tbody.innerHTML = `
                <tr>
                    <td colspan="5" class="text-center py-5 text-muted">
                        <i class="bi bi-info-circle me-1 fs-5"></i>
                        <p class="mb-0 mt-1">${message}</p>
                    </td>
                </tr>`;
        }

        function renderQueueTable() {
            const list = allQueuePatients;
            const doctorId = document.getElementById('ddlDoctorDashboard')?.value || 0;
            
            // Count active vs completed in the result set
            const activePatients = list.filter(item => item.status === 'Consulting' || item.status === 'Skipped');
            const completedPatients = list.filter(item => item.status === 'Completed');
            
            // Update tab count badges
            const badgeActive = document.getElementById('badgeActiveCount');
            const badgeCompleted = document.getElementById('badgeCompletedCount');
            if (badgeActive) badgeActive.innerText = activePatients.length;
            if (badgeCompleted) badgeCompleted.innerText = completedPatients.length;
            
            const filteredList = activeQueueTab === 'active' ? activePatients : completedPatients;
            
            const tbody = document.querySelector('#queueTable tbody');
            tbody.innerHTML = '';
            
            if (filteredList.length === 0) {
                renderEmptyQueue(activeQueueTab === 'active' 
                    ? "No pending patients in consulting queue for this doctor today."
                    : "No completed consultations today yet.");
                
                if (activeOPDServiceId) {
                    const exists = list.some(x => x.opdServiceId === activeOPDServiceId);
                    if (!exists) {
                        clearActivePatient();
                    }
                }
                return;
            }

            filteredList.forEach(item => {
                const tr = document.createElement('tr');
                tr.id = `queueRow-${item.opdServiceId}`;
                if (item.opdServiceId === activeOPDServiceId) {
                    tr.classList.add('active-row');
                }
                
                const visitTime = item.visitDate
                    ? new Date(item.visitDate).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
                    : '--:--';
                    
                const pyStatus = (item.paymentStatus || 'U').toUpperCase();
                const hasDue = pyStatus === 'U' || pyStatus === 'R';
                const dueBadge = hasDue
                    ? `<span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2 py-1.5 font-xs">
                           <i class="bi bi-exclamation-triangle-fill me-1"></i>${pyStatus === 'R' ? 'PARTIAL DUE' : 'DUE'}
                       </span>`
                    : `<span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1.5 font-xs">
                           <i class="bi bi-check-circle-fill me-1"></i>CLEARED
                       </span>`;

                // Called patient indicator
                const isCalled = calledPatientsSet.has(item.opdServiceId);
                const isCurrentlyCalling = callingPatientId === item.opdServiceId;
                
                let callingAnim = '';
                if (isCurrentlyCalling) {
                    callingAnim = `
                        <div class="sound-wave">
                            <span></span><span></span><span></span><span></span>
                        </div>
                    `;
                }
                
                const statusBadge = item.status === 'Completed'
                    ? `<span class="badge bg-success text-white border border-success px-2 py-1.5 font-xs"><i class="bi bi-check-circle-fill me-1"></i>COMPLETED</span>`
                    : item.status === 'Skipped'
                        ? `<span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1.5 font-xs ms-1"><i class="bi bi-skip-forward-fill me-1"></i>SKIPPED</span>`
                        : isCalled 
                            ? `<span class="badge bg-info-subtle text-info border border-info px-2 py-1.5 font-xs ms-1 d-inline-flex align-items-center"><i class="bi bi-megaphone-fill me-1"></i>CALLED ${callingAnim}</span>` 
                            : item.isEmrDone
                                ? `<span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1.5 font-xs ms-1"><i class="bi bi-clipboard2-check-fill me-1"></i>EMR DONE</span>`
                                : `<span class="badge bg-secondary-subtle text-secondary border px-2 py-1.5 font-xs ms-1">WAITING</span>`;

                // Action buttons based on status
                let actionButtons = '';
                if (item.status === 'Completed') {
                    actionButtons = `
                        <button class="btn btn-sm btn-outline-success fw-semibold rounded-pill px-2 shadow-xs text-nowrap" onclick="startConsulting(${item.opdServiceId}, ${item.patientId}, '${item.patientName}', '${item.patientCode}', '${item.gender}', ${item.age}, '${item.tokenNo || ''}', ${hasDue})">
                            <i class="bi bi-eye me-1"></i> Review Record
                        </button>
                    `;
                } else {
                    const skipButton = item.status === 'Skipped' ? '' : `
                        <button class="btn btn-sm btn-outline-danger rounded-circle" style="width: 32px; height: 32px; padding: 0;" title="Skip/Pass Patient" onclick="skipConsulting(${item.opdServiceId})">
                            <i class="bi bi-skip-forward"></i>
                        </button>
                    `;
                    actionButtons = `
                        <button class="btn btn-sm btn-primary fw-semibold rounded-pill px-2 shadow-xs text-nowrap" onclick="startConsulting(${item.opdServiceId}, ${item.patientId}, '${item.patientName}', '${item.patientCode}', '${item.gender}', ${item.age}, '${item.tokenNo || ''}', ${hasDue})">
                            <i class="bi bi-journal-medical me-1"></i> Start EMR
                        </button>
                        <button class="btn btn-sm btn-outline-warning rounded-circle" style="width: 32px; height: 32px; padding: 0;" title="Call Patient" onclick="callPatient(${item.opdServiceId}, '${item.patientName}', '${item.tokenNo}')">
                            <i class="bi bi-megaphone"></i>
                        </button>
                        ${skipButton}
                        <button class="btn btn-sm btn-success rounded-circle" style="width: 32px; height: 32px; padding: 0;" title="Mark Consultation Completed" onclick="completeConsulting(${item.opdServiceId}, '${item.patientName}', ${item.isEmrDone})">
                            <i class="bi bi-check-lg"></i>
                        </button>
                    `;
                }

                if (item.isEmrDone) {
                    actionButtons += `
                        <button class="btn btn-sm btn-outline-primary rounded-circle ms-1" style="width: 32px; height: 32px; padding: 0;" title="Print Prescription" onclick="window.open('/OPD/PrintPrescription?opdServiceId=${item.opdServiceId}&doctorId=${doctorId}', '_blank')">
                            <i class="bi bi-printer"></i>
                        </button>
                    `;
                }

                tr.innerHTML = `
                    <td class="ps-3"><span class="badge bg-light text-secondary border font-monospace fs-6 px-3 py-1.5 shadow-sm">${item.tokenNo || 'N/A'}</span></td>
                    <td>
                        <div class="fw-bold text-dark">${item.patientName}</div>
                        <div class="text-secondary small" style="font-size:0.78rem;">${item.patientCode} • ${item.gender || '-'}, ${item.age || '-'} Yrs</div>
                    </td>
                    <td><span class="badge bg-light text-dark border px-2 py-1.5"><i class="bi bi-clock me-1 text-primary"></i>${visitTime}</span></td>
                    <td>
                        <div class="d-flex flex-column gap-1 align-items-start">
                            ${dueBadge}
                            ${statusBadge}
                        </div>
                    </td>
                    <td class="text-end pe-3">
                        <div class="d-flex justify-content-end gap-1">
                            ${actionButtons}
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            filterQueueTable();
        }

        function startConsulting(opdServiceId, patientId, name, code, gender, age, tokenNo, hasDue) {
            document.querySelectorAll('#queueTable tbody tr').forEach(tr => tr.classList.remove('active-row'));
            const row = document.getElementById(`queueRow-${opdServiceId}`);
            if (row) row.classList.add('active-row');

            activePatientId = patientId;
            activeOPDServiceId = opdServiceId;

            // Find current status from global array
            const patientObj = allQueuePatients.find(x => x.opdServiceId === opdServiceId);
            const isCompleted = patientObj && patientObj.status === 'Completed';

            // Update top status card
            document.getElementById('statActivePatient').innerText = `${tokenNo} - ${name}`;

            // Load patient info panel
            const photoUrl = patientObj ? patientObj.photoPath : null;
            const avatarHtml = photoUrl
                ? `<img src="${photoUrl}" class="rounded-circle border" style="width: 44px; height: 44px; object-fit: cover; flex-shrink: 0;" alt="${name}" />`
                : `<div class="rounded-circle bg-light-primary text-primary d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; font-size: 1.4rem; flex-shrink: 0; background-color: rgba(99,102,241,0.08);">
                       <i class="bi bi-person-workspace"></i>
                   </div>`;

            const panel = document.getElementById('patientDetailCard');
            panel.innerHTML = `
                <div class="card-header bg-primary text-white py-2 px-3 rounded-top-12 d-flex justify-content-between align-items-center shadow-xs">
                    <span class="fw-bold small" style="font-size: 0.82rem;"><i class="bi bi-person-vcard me-1.5"></i>Active Patient Profile</span>
                    <span class="badge bg-light text-dark font-monospace" style="font-size: 0.72rem;">Token: ${tokenNo}</span>
                </div>
                <div class="card-body p-2.5">
                    <div class="d-flex align-items-center gap-2.5 pb-2.5 border-bottom mb-2.5">
                        ${avatarHtml}
                        <div class="text-start">
                            <h6 class="fw-bold text-dark mb-0" style="font-size: 0.95rem;">${name}</h6>
                            <p class="small text-muted mb-1 font-monospace" style="font-size: 0.74rem;">${code}</p>
                            <span class="badge bg-light text-secondary border px-2 py-0.5" style="font-size: 0.7rem;">${gender || '-'}, ${age || '-'} Yrs</span>
                        </div>
                    </div>

                    ${hasDue ? `
                    <div class="alert alert-warning py-1.5 px-2.5 small mb-2.5 d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill text-warning fs-6 me-2"></i>
                        <span style="font-size: 0.72rem; line-height: 1.3;"><strong>Attention:</strong> Outstanding payment dues.</span>
                    </div>` : ''}

                    <h6 class="fw-bold text-muted mb-2 small d-flex justify-content-between align-items-center flex-wrap gap-1" style="font-size: 0.78rem;">
                        <span><i class="bi bi-activity text-primary me-1"></i>Latest Vitals</span>
                        <span id="vitalRecordedOn" class="badge bg-light text-secondary border fw-normal" style="font-size: 0.7rem;">Loading...</span>
                    </h6>
                    <div class="row g-2 text-center mb-2.5" id="vitalsGrid">
                        <!-- BP -->
                        <div class="col-6">
                            <div class="vital-box p-1.5 border rounded shadow-xs" id="boxBP">
                                <small class="text-muted d-block" style="font-size:0.72rem;"><i class="bi bi-heart-fill text-danger me-1"></i>BP (SYS/DIA)</small>
                                <span class="fw-bold text-dark fs-6" id="vitalBP">--/--</span>
                                <small class="text-muted d-block" style="font-size:0.6rem; margin-top: -2px;">mmHg</small>
                            </div>
                        </div>
                        <!-- Pulse -->
                        <div class="col-6">
                            <div class="vital-box p-1.5 border rounded shadow-xs" id="boxPulse">
                                <small class="text-muted d-block" style="font-size:0.72rem;"><i class="bi bi-activity text-danger me-1"></i>Pulse Rate</small>
                                <span class="fw-bold text-dark fs-6" id="vitalPulse">--</span>
                                <small class="text-muted d-block" style="font-size:0.6rem; margin-top: -2px;">bpm</small>
                            </div>
                        </div>
                        <!-- Temp -->
                        <div class="col-6">
                            <div class="vital-box p-1.5 border rounded shadow-xs" id="boxTemp">
                                <small class="text-muted d-block" style="font-size:0.72rem;"><i class="bi bi-thermometer-half text-warning me-1"></i>Temperature</small>
                                <span class="fw-bold text-dark fs-6" id="vitalTemp">--</span>
                                <small class="text-muted d-block" style="font-size:0.6rem; margin-top: -2px;">&deg;F</small>
                            </div>
                        </div>
                        <!-- SpO2 -->
                        <div class="col-6">
                            <div class="vital-box p-1.5 border rounded shadow-xs" id="boxSpO2">
                                <small class="text-muted d-block" style="font-size:0.72rem;"><i class="bi bi-droplet-fill text-info me-1"></i>SpO&sub2;</small>
                                <span class="fw-bold text-dark fs-6" id="vitalSpO2">--</span>
                                <small class="text-muted d-block" style="font-size:0.6rem; margin-top: -2px;">%</small>
                            </div>
                        </div>
                        <!-- Weight -->
                        <div class="col-6">
                            <div class="vital-box p-1.5 border rounded shadow-xs" id="boxWeight">
                                <small class="text-muted d-block" style="font-size:0.72rem;"><i class="bi bi-speedometer2 text-success me-1"></i>Weight</small>
                                <span class="fw-bold text-dark fs-6" id="vitalWeight">--</span>
                                <small class="text-muted d-block" style="font-size:0.6rem; margin-top: -2px;">kg</small>
                            </div>
                        </div>
                        <!-- Blood Glucose -->
                        <div class="col-6">
                            <div class="vital-box p-1.5 border rounded shadow-xs" id="boxGlucose">
                                <small class="text-muted d-block" style="font-size:0.72rem;"><i class="bi bi-droplet-half text-primary me-1"></i>Glucose</small>
                                <span class="fw-bold text-dark fs-6" id="vitalGlucose">--</span>
                                <small class="text-muted d-block" style="font-size:0.6rem; margin-top: -2px;" id="vitalGlucoseType">mg/dL</small>
                            </div>
                        </div>
                        <!-- RR & Pain (hidden by default unless they exist) -->
                        <div class="col-6" id="boxRRCol" style="display:none;">
                            <div class="vital-box p-1.5 border rounded shadow-xs" id="boxRR">
                                <small class="text-muted d-block" style="font-size:0.72rem;"><i class="bi bi-lungs-fill text-info me-1"></i>Resp Rate</small>
                                <span class="fw-bold text-dark fs-6" id="vitalRR">--</span>
                                <small class="text-muted d-block" style="font-size:0.6rem; margin-top: -2px;">rpm</small>
                            </div>
                        </div>
                        <div class="col-6" id="boxPainCol" style="display:none;">
                            <div class="vital-box p-1.5 border rounded shadow-xs" id="boxPain">
                                <small class="text-muted d-block" style="font-size:0.72rem;"><i class="bi bi-emoji-expressionless-fill text-warning me-1"></i>Pain Score</small>
                                <span class="fw-bold text-dark fs-6" id="vitalPain">--</span>
                                <small class="text-muted d-block" style="font-size:0.6rem; margin-top: -2px;">/10</small>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-between border-top pt-2.5 mb-2.5">
                        <a href="/Vitals/History?patientId=${patientId}" target="_blank" class="btn btn-sm btn-outline-info flex-fill fw-semibold py-1" style="font-size: 0.76rem;">
                            <i class="bi bi-clock-history me-1"></i> History
                        </a>
                        <a href="/Vitals/RecordVital?patientId=${patientId}&opdServiceId=${opdServiceId}&returnUrl=%2FOPD%2FDoctorDashboard%3FpatientId%3D${patientId}" class="btn btn-sm btn-outline-primary flex-fill fw-semibold py-1" style="font-size: 0.76rem;">
                            <i class="bi bi-plus-circle me-1"></i> Add Vitals
                        </a>
                    </div>

                    <button class="btn btn-primary w-100 mt-2 py-2 fw-bold shadow-xs rounded-3" style="font-size: 0.82rem;" onclick="triggerEMRStub()">
                        <i class="bi bi-journal-medical me-1.5"></i>Open EMR Consulting Record
                    </button>
                </div>
            `;

            fetchPatientVitals(patientId);
        }

        function setBoxStatus(boxId, status) {
            const el = document.getElementById(boxId);
            if (!el) return;
            el.classList.remove('normal', 'warning', 'critical');
            
            if (status === 'ok') {
                el.classList.add('normal');
            } else if (status === 'warn') {
                el.classList.add('warning');
            } else if (status === 'high') {
                el.classList.add('critical');
            }
        }

        async function fetchPatientVitals(patientId) {
            try {
                const res = await fetch(`/Vitals/GetLatest?patientId=${patientId}`);
                const data = await res.json();
                
                const bpEl = document.getElementById('vitalBP');
                const pulseEl = document.getElementById('vitalPulse');
                const tempEl = document.getElementById('vitalTemp');
                const weightEl = document.getElementById('vitalWeight');
                const spo2El = document.getElementById('vitalSpO2');
                const glucoseEl = document.getElementById('vitalGlucose');
                const glucoseTypeEl = document.getElementById('vitalGlucoseType');
                const rrEl = document.getElementById('vitalRR');
                const painEl = document.getElementById('vitalPain');
                
                const dateEl = document.getElementById('vitalRecordedOn');
                
                if (data && data.found) {
                    if (bpEl) bpEl.innerText = `${data.bpSystolic || '--'}/${data.bpDiastolic || '--'}`;
                    if (pulseEl) pulseEl.innerText = data.pulseRate ? `${data.pulseRate}` : '--';
                    if (tempEl) tempEl.innerText = data.temperature ? `${data.temperature}` : '--';
                    if (weightEl) weightEl.innerText = data.weight ? `${data.weight}` : '--';
                    if (spo2El) spo2El.innerText = data.spO2 ? `${data.spO2}` : '--';
                    if (glucoseEl) glucoseEl.innerText = data.bloodGlucose ? `${data.bloodGlucose}` : '--';
                    if (glucoseTypeEl && data.bloodGlucose) glucoseTypeEl.innerText = `mg/dL (${data.glucoseType || 'Random'})`;

                    // Dynamic classification & alert coloring
                    if (data.bpSystolic && data.bpDiastolic) {
                        const sys = data.bpSystolic;
                        const dia = data.bpDiastolic;
                        const okBP = sys >= 90 && sys <= 120 && dia >= 60 && dia <= 80;
                        const warnBP = !okBP && sys < 140 && dia < 90;
                        setBoxStatus('boxBP', okBP ? 'ok' : warnBP ? 'warn' : 'high');
                    }
                    if (data.pulseRate) {
                        const p = data.pulseRate;
                        const s = p >= 60 && p <= 100 ? 'ok' : p < 50 || p > 120 ? 'high' : 'warn';
                        setBoxStatus('boxPulse', s);
                    }
                    if (data.temperature) {
                        const t = data.temperature;
                        const s = t >= 97 && t <= 99 ? 'ok' : t < 95 || t > 101 ? 'high' : 'warn';
                        setBoxStatus('boxTemp', s);
                    }
                    if (data.spO2) {
                        const s = data.spO2;
                        const status = s >= 95 ? 'ok' : s < 90 ? 'high' : 'warn';
                        setBoxStatus('boxSpO2', status);
                    }
                    if (data.bloodGlucose) {
                        const g = data.bloodGlucose;
                        const s = g >= 70 && g <= 140 ? 'ok' : g > 300 ? 'high' : 'warn';
                        setBoxStatus('boxGlucose', s);
                    }

                    // Optional fields
                    if (data.respiratoryRate) {
                        if (rrEl) rrEl.innerText = `${data.respiratoryRate}`;
                        const r = data.respiratoryRate;
                        const s = r >= 12 && r <= 20 ? 'ok' : r < 8 || r > 30 ? 'high' : 'warn';
                        setBoxStatus('boxRR', s);
                        document.getElementById('boxRRCol').style.display = '';
                    } else {
                        document.getElementById('boxRRCol').style.display = 'none';
                    }

                    if (data.painScore !== null && data.painScore !== undefined) {
                        if (painEl) painEl.innerText = `${data.painScore}`;
                        const ps = data.painScore;
                        const s = ps <= 3 ? 'ok' : ps <= 6 ? 'warn' : 'high';
                        setBoxStatus('boxPain', s);
                        document.getElementById('boxPainCol').style.display = '';
                    } else {
                        document.getElementById('boxPainCol').style.display = 'none';
                    }

                    if (dateEl) dateEl.innerText = `Recorded: ${data.recordedOn || 'N/A'}`;
                } else {
                    // Set all to default blank
                    if (bpEl) bpEl.innerText = '--/--';
                    if (pulseEl) pulseEl.innerText = '--';
                    if (tempEl) tempEl.innerText = '--';
                    if (weightEl) weightEl.innerText = '--';
                    if (spo2El) spo2El.innerText = '--';
                    if (glucoseEl) glucoseEl.innerText = '--';
                    document.getElementById('boxRRCol').style.display = 'none';
                    document.getElementById('boxPainCol').style.display = 'none';
                    
                    setBoxStatus('boxBP', '');
                    setBoxStatus('boxPulse', '');
                    setBoxStatus('boxTemp', '');
                    setBoxStatus('boxSpO2', '');
                    setBoxStatus('boxWeight', '');
                    setBoxStatus('boxGlucose', '');

                    if (dateEl) dateEl.innerText = 'No records';
                }
            } catch (err) {
                console.error("Vitals load failed:", err);
                const dateEl = document.getElementById('vitalRecordedOn');
                if (dateEl) dateEl.innerText = 'Error loading';
            }
        }

