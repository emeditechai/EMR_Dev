        function getVoiceForGender(gender) {
            const voices = window.speechSynthesis.getVoices();
            if (!voices || voices.length === 0) return null;

            const g = (gender || 'Male').toLowerCase();
            const enVoices = voices.filter(v => v.lang.startsWith('en-') || v.lang.startsWith('en_'));
            const candidateVoices = enVoices.length > 0 ? enVoices : voices;

            if (g === 'female') {
                const femaleKeywords = ['female', 'zira', 'samantha', 'karen', 'hazel', 'susan', 'victoria', 'google us english', 'fiona', 'tessa', 'moira', 'veena'];
                for (const kw of femaleKeywords) {
                    const match = candidateVoices.find(v => v.name.toLowerCase().includes(kw));
                    if (match) return match;
                }
                return candidateVoices[0];
            } else {
                const maleKeywords = ['male', 'david', 'alex', 'daniel', 'george', 'ravi', 'microsoft david', 'mark'];
                for (const kw of maleKeywords) {
                    const match = candidateVoices.find(v => {
                        const nameLower = v.name.toLowerCase();
                        return nameLower.includes(kw) && (kw !== 'male' || !nameLower.includes('female'));
                    });
                    if (match) return match;
                }
                return candidateVoices[0];
            }
        }

