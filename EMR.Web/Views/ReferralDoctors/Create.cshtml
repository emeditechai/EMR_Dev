@model EMR.Web.Models.Entities.ReferralDoctorMaster
@{
    ViewData["Title"] = "Add Referral Doctor";
    var salutations = ViewBag.Salutations as List<string> ?? new List<string>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 fw-bold">Add Referral Doctor</h1>
        <small class="text-muted">Create a new external referral doctor record</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="dashboard-panel" style="max-width:700px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="row g-3 mb-3">
            <div class="col-sm-3">
                <label asp-for="Salutation" class="form-label fw-semibold">Salutation</label>
                <select asp-for="Salutation" class="form-select">
                    <option value="">-</option>
                    @foreach (var s in salutations)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <span asp-validation-for="Salutation" class="text-danger small"></span>
            </div>
            <div class="col-sm-9">
                <label asp-for="DoctorName" class="form-label fw-semibold">
                    Doctor Name <span class="text-danger">*</span>
                </label>
                <input asp-for="DoctorName" class="form-control" maxlength="150" placeholder="e.g. John Doe" />
                <span asp-validation-for="DoctorName" class="text-danger small"></span>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-sm-6">
                <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                <input asp-for="PhoneNumber" class="form-control" maxlength="15" placeholder="e.g. 9876543210" />
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>
            <div class="col-sm-6">
                <label asp-for="EmailId" class="form-label fw-semibold">Email ID</label>
                <input asp-for="EmailId" class="form-control" type="email" maxlength="150" placeholder="e.g. doctor@example.com" />
                <span asp-validation-for="EmailId" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="RegistrationNumber" class="form-label fw-semibold">Registration Number</label>
            <input asp-for="RegistrationNumber" class="form-control" maxlength="50" placeholder="Optional registration number" />
            <span asp-validation-for="RegistrationNumber" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" checked />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-save me-1"></i>Save
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
