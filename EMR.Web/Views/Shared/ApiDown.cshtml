@{
    ViewData["Title"] = "Service Unavailable";
    var pageName = ViewData["PageName"] as string ?? "This page";
}

<div class="d-flex flex-column align-items-center justify-content-center" style="min-height:60vh; text-align:center; padding: 2rem;">

    <div style="max-width:520px; width:100%;">

        <!-- Icon -->
        <div style="margin-bottom:1.5rem;">
            <div style="
                width:96px; height:96px; border-radius:50%;
                background:linear-gradient(135deg,#fff3cd,#ffe08a);
                display:flex; align-items:center; justify-content:center;
                margin:0 auto; box-shadow:0 4px 20px rgba(255,193,7,.35);">
                <i class="bi bi-plug-fill" style="font-size:2.8rem; color:#cc8400;"></i>
            </div>
        </div>

        <!-- Heading -->
        <h1 class="fw-bold mb-2" style="font-size:1.75rem; color:#212529;">
            API Server is Down
        </h1>
        <p class="text-muted mb-1" style="font-size:1rem;">
            <strong>@pageName</strong> is currently unable to connect to the backend API service.
        </p>
        <p class="text-muted mb-4" style="font-size:.95rem;">
            The service running on <code>EMR.Api</code> appears to be unreachable.
        </p>

        <!-- Alert box -->
        <div class="alert alert-warning d-flex align-items-start gap-3 text-start" role="alert"
             style="border-radius:12px; border-left:4px solid #ffc107;">
            <i class="bi bi-exclamation-triangle-fill fs-4 mt-1 flex-shrink-0" style="color:#cc8400;"></i>
            <div>
                <strong>What you can do:</strong>
                <ul class="mb-0 mt-1" style="padding-left:1.1rem;">
                    <li>Wait a moment and <a href="javascript:location.reload()" class="alert-link">refresh the page</a>.</li>
                    <li>Contact your system administrator to restart the API service.</li>
                    <li>Check that <code>EMR.Api</code> is running on port <code>5125</code>.</li>
                </ul>
            </div>
        </div>

        <!-- Action buttons -->
        <div class="d-flex gap-2 justify-content-center flex-wrap mt-2">
            <a href="javascript:location.reload()"
               class="btn btn-warning px-4"
               style="border-radius:8px; font-weight:600;">
                <i class="bi bi-arrow-clockwise me-1"></i> Retry
            </a>
            <a href="/" class="btn btn-outline-secondary px-4" style="border-radius:8px;">
                <i class="bi bi-house me-1"></i> Go to Dashboard
            </a>
        </div>

        <!-- Footer note -->
        <p class="text-muted mt-4" style="font-size:.8rem;">
            <i class="bi bi-shield-lock me-1"></i>
            Please contact your administrator if this issue persists.
        </p>

    </div>
</div>
