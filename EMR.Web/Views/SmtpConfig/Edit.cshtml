@model EMR.Web.Models.ViewModels.SmtpConfigFormViewModel
@{
    ViewData["Title"] = "Edit Email Configuration";
}

@section HeadStyles {
<style>
    /* ── Provider Preset Cards ── */
    .provider-presets { display:flex; gap:.75rem; flex-wrap:wrap; margin-bottom:1.5rem; }
    .provider-preset { cursor:pointer; border:2px solid #e9ecef; border-radius:12px; padding:.8rem 1.2rem; display:flex; align-items:center; gap:.6rem; transition:all .2s; background:#fff; min-width:140px; }
    .provider-preset:hover { border-color:#adb5bd; transform:translateY(-1px); box-shadow:0 4px 12px rgba(0,0,0,.06); }
    .provider-preset.active { border-color:var(--emr-primary); background:linear-gradient(135deg,#eef2ff,#e8f0fe); box-shadow:0 4px 16px rgba(99,102,241,.12); }
    .provider-preset .p-icon { width:36px; height:36px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; flex-shrink:0; }
    .provider-preset .p-icon.gmail   { background:linear-gradient(135deg,#ea4335,#fbbc05); color:#fff; }
    .provider-preset .p-icon.outlook { background:linear-gradient(135deg,#0078d4,#00bcf2); color:#fff; }
    .provider-preset .p-icon.yahoo   { background:linear-gradient(135deg,#6001d2,#a88fcc); color:#fff; }
    .provider-preset .p-icon.custom  { background:linear-gradient(135deg,#6c757d,#adb5bd); color:#fff; }
    .provider-preset .p-label { font-weight:700; font-size:.85rem; color:#343a40; }
    .provider-preset .p-desc  { font-size:.7rem; color:#6c757d; }

    /* ── Form sections ── */
    .smtp-form-section { background:#fff; border:1px solid #e9ecef; border-radius:14px; padding:1.5rem; margin-bottom:1.25rem; box-shadow:0 2px 8px rgba(0,0,0,.03); }
    .smtp-form-section .section-title { font-weight:700; font-size:.85rem; text-transform:uppercase; letter-spacing:.05em; color:var(--emr-primary); margin-bottom:1rem; display:flex; align-items:center; gap:.5rem; }
    .smtp-form-section .section-title i { font-size:1rem; }

    /* ── Toggle switch ── */
    .toggle-row { display:flex; align-items:center; justify-content:space-between; padding:.6rem 0; border-bottom:1px solid #f3f4f6; }
    .toggle-row:last-child { border-bottom:0; }
    .toggle-row .toggle-label { font-weight:600; font-size:.85rem; color:#343a40; }
    .toggle-row .toggle-desc  { font-size:.72rem; color:#9ca3af; }

    /* ── Password toggle ── */
    .pwd-toggle { cursor:pointer; position:absolute; right:10px; top:50%; transform:translateY(-50%); color:#6c757d; font-size:.9rem; z-index:5; }
    .pwd-toggle:hover { color:#343a40; }

    /* ── Help tooltip ── */
    .help-link { font-size:.72rem; color:#6c757d; text-decoration:underline; cursor:pointer; }
    .help-link:hover { color:var(--emr-primary); }
</style>
}

@* ── Page Header ── *@
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-2">
        <i class="bi bi-pencil-square fs-4" style="color:var(--emr-primary)"></i>
        <div>
            <h1 class="h4 mb-0 fw-bold">Edit Email Configuration</h1>
            <small class="text-muted">Branch: <strong>@Model.BranchName</strong> &mdash; Editing: <strong>@Model.ConfigName</strong></small>
        </div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

@* ── Provider Quick-Select ── *@
<div class="smtp-form-section">
    <div class="section-title"><i class="bi bi-lightning-fill"></i>Provider</div>
    <div class="provider-presets">
        <div class="provider-preset @(Model.ProviderType == "Gmail" ? "active" : "")" onclick="selectProvider('Gmail','smtp.gmail.com',587,true,true)">
            <div class="p-icon gmail"><i class="bi bi-google"></i></div>
            <div>
                <div class="p-label">Gmail</div>
                <div class="p-desc">smtp.gmail.com : 587</div>
            </div>
        </div>
        <div class="provider-preset @(Model.ProviderType == "Outlook" ? "active" : "")" onclick="selectProvider('Outlook','smtp.office365.com',587,true,true)">
            <div class="p-icon outlook"><i class="bi bi-microsoft"></i></div>
            <div>
                <div class="p-label">Outlook / Office 365</div>
                <div class="p-desc">smtp.office365.com : 587</div>
            </div>
        </div>
        <div class="provider-preset @(Model.ProviderType == "Yahoo" ? "active" : "")" onclick="selectProvider('Yahoo','smtp.mail.yahoo.com',465,true,false)">
            <div class="p-icon yahoo"><i class="bi bi-yahoo"></i></div>
            <div>
                <div class="p-label">Yahoo</div>
                <div class="p-desc">smtp.mail.yahoo.com : 465</div>
            </div>
        </div>
        <div class="provider-preset @(Model.ProviderType == "Custom" ? "active" : "")" onclick="selectProvider('Custom','','',true,true)">
            <div class="p-icon custom"><i class="bi bi-gear-fill"></i></div>
            <div>
                <div class="p-label">Custom / Corporate</div>
                <div class="p-desc">Enter details manually</div>
            </div>
        </div>
    </div>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ProviderType" id="providerType" />
    <input type="hidden" asp-for="BranchId" />
    <input type="hidden" asp-for="IsEdit" />

    <div class="row g-3">
        @* ── Left Column: Connection & Auth ── *@
        <div class="col-12 col-lg-7">
            @* Connection Settings *@
            <div class="smtp-form-section">
                <div class="section-title"><i class="bi bi-hdd-network-fill"></i>Connection Settings</div>
                <div class="row g-3">
                    <div class="col-12 col-md-8">
                        <label asp-for="SmtpHost" class="form-label fw-semibold">SMTP Host <span class="text-danger">*</span></label>
                        <input asp-for="SmtpHost" class="form-control" id="smtpHost" placeholder="e.g. smtp.gmail.com" />
                        <span asp-validation-for="SmtpHost" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="SmtpPort" class="form-label fw-semibold">Port <span class="text-danger">*</span></label>
                        <input asp-for="SmtpPort" class="form-control" id="smtpPort" type="number" min="1" max="65535" />
                        <span asp-validation-for="SmtpPort" class="text-danger small"></span>
                    </div>
                </div>
                <div class="mt-3">
                    <div class="toggle-row">
                        <div>
                            <div class="toggle-label"><i class="bi bi-shield-lock me-1"></i>Enable SSL / TLS</div>
                            <div class="toggle-desc">Recommended for secure email delivery</div>
                        </div>
                        <div class="form-check form-switch">
                            <input asp-for="UseSsl" class="form-check-input" type="checkbox" role="switch" id="useSsl" />
                        </div>
                    </div>
                    <div class="toggle-row">
                        <div>
                            <div class="toggle-label"><i class="bi bi-shield-check me-1"></i>Enable STARTTLS</div>
                            <div class="toggle-desc">Upgrade connection to TLS after connecting</div>
                        </div>
                        <div class="form-check form-switch">
                            <input asp-for="UseStartTls" class="form-check-input" type="checkbox" role="switch" id="useStartTls" />
                        </div>
                    </div>
                </div>
            </div>

            @* Authentication *@
            <div class="smtp-form-section">
                <div class="section-title"><i class="bi bi-key-fill"></i>Authentication</div>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="Username" class="form-label fw-semibold">Username <span class="text-danger">*</span></label>
                        <input asp-for="Username" class="form-control" placeholder="your-email@gmail.com" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="Password" class="form-label fw-semibold">
                            Password
                        </label>
                        <div class="position-relative">
                            <input asp-for="Password" type="password" class="form-control pe-5" id="passwordField" placeholder="Leave blank to keep existing" />
                            <span class="pwd-toggle" onclick="togglePassword()"><i class="bi bi-eye-fill" id="pwdIcon"></i></span>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                        <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Leave blank to keep the existing password.</small>
                    </div>
                </div>
            </div>
        </div>

        @* ── Right Column: Sender & Meta ── *@
        <div class="col-12 col-lg-5">
            @* Sender Details *@
            <div class="smtp-form-section">
                <div class="section-title"><i class="bi bi-person-badge-fill"></i>Sender Details</div>
                <div class="mb-3">
                    <label asp-for="SenderEmail" class="form-label fw-semibold">Sender Email <span class="text-danger">*</span></label>
                    <input asp-for="SenderEmail" class="form-control" placeholder="noreply@yourhospital.com" />
                    <span asp-validation-for="SenderEmail" class="text-danger small"></span>
                </div>
                <div>
                    <label asp-for="SenderDisplayName" class="form-label fw-semibold">Display Name</label>
                    <input asp-for="SenderDisplayName" class="form-control" placeholder="eClinicPlus+ Hospital" />
                    <span asp-validation-for="SenderDisplayName" class="text-danger small"></span>
                </div>
            </div>

            @* Configuration Meta *@
            <div class="smtp-form-section">
                <div class="section-title"><i class="bi bi-tag-fill"></i>Configuration</div>
                <div class="mb-3">
                    <label asp-for="ConfigName" class="form-label fw-semibold">Configuration Name <span class="text-danger">*</span></label>
                    <input asp-for="ConfigName" class="form-control" placeholder="e.g. Hospital Gmail, Corporate Mail" />
                    <span asp-validation-for="ConfigName" class="text-danger small"></span>
                </div>
                <div class="toggle-row">
                    <div>
                        <div class="toggle-label"><i class="bi bi-star-fill me-1 text-warning"></i>Set as Default</div>
                        <div class="toggle-desc">Use this config as the primary email sender for this branch</div>
                    </div>
                    <div class="form-check form-switch">
                        <input asp-for="IsDefault" class="form-check-input" type="checkbox" role="switch" />
                    </div>
                </div>
                <div class="toggle-row">
                    <div>
                        <div class="toggle-label"><i class="bi bi-toggle-on me-1 text-success"></i>Active</div>
                        <div class="toggle-desc">Enable or disable this configuration</div>
                    </div>
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                    </div>
                </div>
            </div>

            @* Submit *@
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-check-circle-fill me-1"></i>Update Configuration
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>

    @* Validation Summary *@
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger mt-3">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>
            <strong>Please fix the following errors:</strong>
            <div asp-validation-summary="All" class="mt-1"></div>
        </div>
    }
</form>

@section Scripts {
<script>
    function selectProvider(type, host, port, ssl, starttls) {
        document.getElementById('providerType').value = type;
        if (host) document.getElementById('smtpHost').value = host;
        if (port) document.getElementById('smtpPort').value = port;
        document.getElementById('useSsl').checked = ssl;
        document.getElementById('useStartTls').checked = starttls;

        // Toggle active class
        document.querySelectorAll('.provider-preset').forEach(function (el) { el.classList.remove('active'); });
        event.currentTarget.classList.add('active');
    }

    function togglePassword() {
        var field = document.getElementById('passwordField');
        var icon = document.getElementById('pwdIcon');
        if (field.type === 'password') {
            field.type = 'text';
            icon.className = 'bi bi-eye-slash-fill';
        } else {
            field.type = 'password';
            icon.className = 'bi bi-eye-fill';
        }
    }
</script>
}
